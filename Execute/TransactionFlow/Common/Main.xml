		<InvokeWorkflow ID="ID_InvokePassbookWorkflow" UI="" comment="Invoke maintenance workflow" name="PrintBankbook" syn="0">
			<Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow"/>
		</InvokeWorkflow>
		<!--设置用户模式，3为Generap Help-->
		<SetData ID="ID_SetUserModeType" saveBuffer="{VTMA.send.CallRemoteTeller.userModeType,0}" value="3">
			<Forward event="OnConfirm" targetID="ID_SetGeneralHelperModeFlag"/>
		</SetData>
		<!--设置Generap Help标志，返回零状态不显示数字人-->
		<SetData ID="ID_SetGeneralHelperModeFlag" saveBuffer="{VTM_GeneralHelperModeFlag,0}" value="1">
			<Forward event="OnConfirm" targetID="ID_SetTransValue"/>
		</SetData>
		<!--设置业务类型，1为其他业务-->
		<SetData ID="ID_SetTransValue" saveBuffer="{VTMA.send.CallRemoteTeller.args.businessInfo.transaction,0}" value="0">
			<Forward event="OnConfirm" targetID="ID_InvokeCallAgentWorkflow"/>
		</SetData>
		<InvokeWorkflow ID="ID_InvokeCallAgentWorkflow" name="VTMA3CallAgent" comment="Invoke CallAgent workflow" index="0">
			<Forward event="OnConfirm" targetID="ID_CompareModeFlagAndGoZeroState"/>
		</InvokeWorkflow>	
		<End ID="9999" comment="End">
		</End>
	</Activities>
	<DefaultForward>
		<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnKeyError" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnHelp" targetID="ID_SetUserModeType"/>
	</DefaultForward>
</Workflow>