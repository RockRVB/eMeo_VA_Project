<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="VAB_NoCard_CashWithdrawal">
	<Head type="GRGWorkflow" author="rocky" timeStamp="" comment="The workflow design is for NoCard_CashWithdrawal"/>
	<DataPool></DataPool>
	<Activities>
		<Start ID="0" comment="Start" callVisible="0" endflag="1">
			<Forward event="OnConfirm" targetID="ID_CheckTotalRemain"/>
		</Start>
		<VAB_CWDCheckRemain ID="ID_CheckTotalRemain" UI="" comment="">
			<States>
				<State name="CRMNotAvailable" UI="UI_VAB_CRMNotAvailable" />
			</States>
			<Forward event="OnContinue" targetID="ID_CDMGetDevStatusCWD" />
			<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		</VAB_CWDCheckRemain>
		<GetDevStatusEx ID="ID_CDMGetDevStatusCWD" UI="" comment="Get device status" devType="CDM" callVisible="0">
			<States>
				<State name="GetDevStatusExError" UI="UI_VAB_CRMNotAvailable" />
			</States>
			<Forward event="OnNormal" targetID="ID_TransactionFlowStart" />
			<Forward event="OnWarn" targetID="ID_TransactionFlowStart" />
			<Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
		</GetDevStatusEx>
		<WriteEJLog ID="ID_TransactionFlowStart" LogData ="***==================================================*;   TRANSACTION START: CASH WITHDRAWAL NO CARD">
			<Forward event="OnConfirm" targetID="ID_SetTransType"/>
		</WriteEJLog>
		<VAB_CreateSessionIDNumber ID="ID_CreateSessionIDNumber">
			<Forward event="OnNext" targetID="ID_InvokeLoginWorkflow" />
		</VAB_CreateSessionIDNumber>
		<SetData ID="ID_SetTransType" saveBuffer="{VTM_TransTypeName,1}" value="CashWithdrawal_NoCard">
			<Forward event="OnConfirm" targetID="ID_CreateSessionIDNumber"/>
		</SetData>
		<InvokeWorkflow ID="ID_InvokeLoginWorkflow" name="VAB_VerifyCustomer" comment="Invoke VAB_VerifyCustomer workflow">
			<Forward event="OnConfirm" targetID="ID_QueryCIFInfo"/>
		</InvokeWorkflow>
		<RequestTransViaRestful ID="ID_QueryCIFInfo" UI="UI_VAB_Processing" transType="QueryCustomerInfo" transFormat="json" timeout="60000">
			<States>
				<State name="PackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ConnectFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="SendFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveTimeout" UI="UI_VAB_QRCWDSystemError"/>
				<State name="NetworkFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="UnpackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HardwareError" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HostRefuse" UI="UI_VAB_QRCWDSystemError"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_CheckExistAccount"/>
			<Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnNetworkFail" targetID="ID_CheckExistAccount"/>
			<Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnHostRefuse" targetID="ID_TransactionfailAndfindAnotherMethod"/>
		</RequestTransViaRestful>
		<CompareData ID="ID_CheckExistAccount" compareBuffer="{VAB_ExistAccount}" comment="Check customer have account to do transaction?">
			<Forward event="OnEqualY" targetID="ID_VAB_CWDSelectAccount"/>
            <Forward event="OnEqualN" targetID="ID_InvokeCloseTransWorkflow"/>
			<DefaultForward targetID="ID_InvokeCloseTransWorkflow"/>
		</CompareData>
		<VAB_CWDSelectAccount ID="ID_VAB_CWDSelectAccount" UI="UI_VAB_CWDSelectAccount" comment="">
			<Forward event="OnContinueWithdraw" targetID="ID_VABSelectWithdrawalAmount"/>
		</VAB_CWDSelectAccount>
		<VAB_InputWithdrawAmount ID="ID_VABSelectWithdrawalAmount" UI="UI_VABSelectWithdrawalAmount" comment="" maxWithdrawalAmount="5000000"  maxRetryTimes="0" homeVisible="1" timeOut="60000">
			<Forward event="OnConfirm" targetID="ID_IsAlreadyDenominated"/>
			<Forward event="OnExit" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnAnotherCashValue" targetID="ID_VABInputWithdrawalAmount"/>
			<Forward event="OnContinue" targetID="ID_VABInputWithdrawalAmount"/>
		</VAB_InputWithdrawAmount>
		<VAB_InputWithdrawAmount ID="ID_VABInputWithdrawalAmount" UI="UI_VABInputWithdrawalAmount" comment="Input withdrawal amount" maxWithdrawalAmount="5000000"  maxRetryTimes="0" homeVisible="1" timeOut="60000">
			<Forward event="OnConfirm" targetID="ID_IsAlreadyDenominated"/>
			<Forward event="OnExit" targetID="ID_InvokeCloseTransWorkflow"/>
		</VAB_InputWithdrawAmount>
		<SetData ID="ID_IsAlreadyDenominated" comment="" saveBufferBool="{core_IsAlreadyDenominated}" value="true">
			<Forward event="OnConfirm" targetID="ID_IsAlreadySentWithdrawalRequest"/>
		</SetData>	
		<SetData ID="ID_IsAlreadySentWithdrawalRequest" comment="" saveBufferBool="{core_IsAlreadySentWithdrawalRequest}" value="true">
			<Forward event="OnConfirm" targetID="ID_IsAlreadyUnpackedWithdrawalTrans"/>
		</SetData>	
		<SetData ID="ID_IsAlreadyUnpackedWithdrawalTrans" comment="" saveBufferBool="{core_IsAlreadyUnpackedWithdrawalTrans}" value="true">
			<Forward event="OnConfirm" targetID="ID_QueryTransFee"/>
		</SetData>
		<RequestTransViaRestful ID="ID_QueryTransFee" UI="UI_VAB_Processing" transType="QueryTransFee" transFormat="json" timeout="60000">
			<States>
				<State name="PackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ConnectFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="SendFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveTimeout" UI="UI_VAB_QRCWDSystemError"/>
				<State name="NetworkFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="UnpackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HardwareError" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HostRefuse" UI="UI_VAB_QRCWDSystemError"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_GetReceiptDevStatus"/>
			<Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnHostRefuse" targetID="ID_TransactionfailAndfindAnotherMethod"/>
		</RequestTransViaRestful>
		<GetDevStatus ID="ID_GetReceiptDevStatus" comment="" devType="RPTR">
			<Forward event="OnNormal" targetID="ID_VABAskPrintReceipt"/>
			<Forward event="OnWarn" targetID="ID_VABAskPrintReceipt"/>
			<Forward event="OnFail" targetID="ID_SetFlagNoPrintReceipt"/>
		</GetDevStatus>
		<VAB_AskPrintReceiptCWD ID="ID_VABAskPrintReceipt" UI="UI_VABAskPrintReceiptCWD" comment="">
			<Forward event="OnNotPrintBillWithdraw" targetID="ID_SetFlagNoPrintReceipt"/>
			<Forward event="OnPrintBillWithdraw" targetID="ID_SetFlagPrintReceipt"/>
		</VAB_AskPrintReceiptCWD>
		<SetData ID="ID_SetFlagPrintReceipt" saveBuffer="{VTM_CWDNoCardReceipt}" value="1">
			<Forward event="OnConfirm" targetID="ID_RequestCWD_NoCard"/>
		</SetData>
		<SetData ID="ID_SetFlagNoPrintReceipt" saveBuffer="{VTM_CWDNoCardReceipt}" value="0">
			<Forward event="OnConfirm" targetID="ID_RequestCWD_NoCard"/>
		</SetData>
		<RequestTransViaRestful ID="ID_RequestCWD_NoCard" UI="UI_VAB_Processing" transType="CashWithdrawalNoCardConfirm" transFormat="json" timeout="60000">
			<States>
				<State name="PackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ConnectFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="SendFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="ReceiveTimeout" UI="UI_VAB_QRCWDSystemError"/>
				<State name="NetworkFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="UnpackFail" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HardwareError" UI="UI_VAB_QRCWDSystemError"/>
				<State name="HostRefuse" UI="UI_VAB_QRCWDSystemError"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_DispenseCash"/>
			<Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnHostRefuse" targetID="ID_TransactionfailAndfindAnotherMethod"/>
		</RequestTransViaRestful>
		<DispenseCash ID="ID_DispenseCash" UI="" comment="Dispense cash">
		  <States>
			<State name="DispenseAmountError" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RejectingCash" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RejectCashForHardwareError" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RejectCashFail" UI="UI_VAB_QRCWDSystemError"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_PresentCash"/>
		  <Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
		</DispenseCash>
		<PresentCash ID="ID_PresentCash" UI="" comment="Present cash">
		  <States>
			<State name="TakeCash" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RetractingCash" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RetractCashForTimeout" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RetractCashForHardwareError" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RetractNoCash" UI="UI_VAB_QRCWDSystemError"/>
			<State name="RetractCashFail" UI="UI_VAB_QRCWDSystemError"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_VAB_CheckFlagPrintReceipt"/>
		  <Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
		</PresentCash>
		<CompareData ID="ID_VAB_CheckFlagPrintReceipt" compareBuffer="{VTM_CWDNoCardReceipt}">
			<Forward event="OnEqual1" targetID="ID_PrintReceiptCWDNocard" />
			<Forward event="OnEqualNull" targetID="ID_InvokeCloseTransWorkflow" />
			<DefaultForward targetID="ID_InvokeCloseTransWorkflow"/>
		</CompareData>
		<PrintReceipt ID="ID_PrintReceiptCWDNocard" UI="" formName="ReceiptFormCWDNonCard" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI=""/>
				<State name="PrintReceiptFail" UI=""/>
			</States>
			<Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow"/>
		</PrintReceipt>
		<InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" name="CloseTrans" comment="Invoke close trans workflow">
			<Forward event="OnConfirm" targetID="9999"/>
		</InvokeWorkflow>
		<End ID="9999" comment="End"></End>
	</Activities>
	<DefaultForward>
		<Forward event="ONEXIT" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnExitConfirm" targetID="ID_AskExitTxn"/>
		<Forward event="OnTimeout" targetID="ID_CheckTimeoutState"/>
		<Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
	</DefaultForward>
</Workflow>
