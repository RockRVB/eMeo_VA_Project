<?xml version="1.0"?>
<Workflow name="FaceRegisterWorkFlow">
  <Head type="GRGWorkflow" author="lnqi" timeStamp="" comment="" />
  <DataPool />
  <Activities>
    <Start ID="0" UI="" comment="Start">
      <Forward event="OnConfirm" targetID="ID_FaceCaptureImage" />
    </Start>
    <FaceCaptureImage ID="ID_FaceCaptureImage" UI="UI_LookCameraTakePic" comment="" timeout="30000" >
      <Forward event="OnConfirm" targetID="ID_CheckFaceImageQuality" />
	  <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
	  <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />	  
    </FaceCaptureImage>
		
	<CheckFaceImageQuality ID="ID_CheckFaceImageQuality" UI="UI_CommonProcessing" comment="" timeout="60000" >
      <Forward event="OnConfirm" targetID="ID_InputFaceUserInfo" />
	  <Forward event="OnFail" targetID="ID_CheckImageQualityFail" />	  
    </CheckFaceImageQuality>
	
	<WaitSleep ID="ID_CheckImageQualityFail" UI="UI_CheckFaceImageQualityFail" comment="Check Image Quality Fail" timeout="4000">
      <Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow" />
    </WaitSleep>
	
   <InputFaceUserInfo ID="ID_InputFaceUserInfo" UI="UI_InputFaceRegisterInfo" comment="" timeout="60000" >
	  <Forward event="OnConfirm" targetID="ID_FaceRegister" />
	  <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
    </InputFaceUserInfo>
	
	<FaceRegister ID="ID_FaceRegister" UI="UI_CommonProcessing" comment="" timeout="300000" >
      <Forward event="OnConfirm" targetID="ID_FaceRegisterSuccessful" />
	  <Forward event="NotMatch" targetID="ID_InvokeCloseTransWorkflow" />
	  <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </FaceRegister>
	
	<WaitSleep ID="ID_FaceRegisterSuccessful" UI="UI_FaceRegisterSuccessful" comment="Face Register Successful" timeout="4000">
      <Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow" />
    </WaitSleep>
	
	
    <End ID="9999" UI="" comment="End" />
    <InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" UI="" comment="Invoke close trans workflow" name="CloseTrans">
      <Forward event="OnConfirm" targetID="9999" />
    </InvokeWorkflow>
  </Activities>
  <DefaultForward>
    <Forward event="OnHardwareError" targetID="ID_DevError" />
    <Forward event="OnFail" targetID="ID_EventError" />
    <Forward event="OnTimeout" targetID="ID_GoTimeOut" />
    <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
  </DefaultForward>
</Workflow>