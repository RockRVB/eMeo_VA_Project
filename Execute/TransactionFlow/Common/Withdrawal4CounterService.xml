<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="Withdrawal4CounterService">
  <Head type="GRGWorkflow" author="" timeStamp="" comment="The workflow design is for withdrawal"/>
  <DataPool>
  </DataPool>
  <Activities>
    <Start ID="0" comment="Start" homeVisible="0">
      <Forward event="OnConfirm" targetID="ID_IsReady4Withdrawal"/>
    </Start>

    <CompareData ID="ID_IsReady4Withdrawal" comment="" compareBuffer="{CounterService_IsReady4Withdrawal}">
      <Forward event="OnEqual1" targetID="ID_IsAlreadySentWithdrawalRequest" />
      <Forward event="OnEqual0" targetID="ID_SetWithdrawalResultError" />
      <DefaultForward targetID="ID_SetWithdrawalResultError" />
    </CompareData>
    <SetData ID="ID_IsAlreadySentWithdrawalRequest" comment="" saveBufferBool="{core_IsAlreadySentWithdrawalRequest}" value="true">
			<DefaultForward targetID="ID_core_IsAlreadyUnpackedWithdrawalTrans"/>
		</SetData>
    <SetData ID="ID_core_IsAlreadyUnpackedWithdrawalTrans" comment="" saveBufferBool="{core_IsAlreadyUnpackedWithdrawalTrans}" value="true">
			<DefaultForward targetID="ID_InputWithdrawalAmount"/>
		</SetData>

    <VTMInputWithdrawAmount ID="ID_InputWithdrawalAmount" comment="Input withdrawal amount" isValetMode="1" maxWithdrawalAmount="5000000" maxRetryTimes="0" homeVisible="1" timeOut="300000">
      <Forward event="OnConfirm" targetID="ID_DispenseCash"/>
      <Forward event="OnCancel" targetID="ID_SetWithdrawalResultCancel"/>
    </VTMInputWithdrawAmount>

    <DispenseCash ID="ID_DispenseCash" UI="UI_PresentCash" digitalVoiceKey="||||" comment="Dispense cash">
      <States>
        <State name="DispenseAmountError" UI="UI_DispenseAmountError"/>
        <State name="RejectingCash" UI="UI_RejectingCash"/>
        <State name="RejectCashForHardwareError" UI="UI_RejectCashForHardwareError"/>
        <State name="RejectCashFail" UI="UI_RejectCashFail"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_PresentCash"/>
      <Forward event="OnHardwareError" targetID="ID_SetWithdrawalResultError"/>
    </DispenseCash>

    <VTMPresentCash ID="ID_PresentCash" UI="UI_PresentCash" digitalVoiceKey="action_071||||||" comment="Present cash">
      <States>
        <State name="TakeCash" UI="UI_TakeCash"/>
        <State name="RetractingCash" UI="UI_RetractingCash"/>
        <State name="RetractCashForTimeout" UI="UI_RetractCashForTimeout"/>
        <State name="RetractCashForHardwareError" UI="UI_RetractCashForHardwareError"/>
        <State name="RetractNoCash" UI="UI_RetractNoCash"/>
        <State name="RetractCashFail" UI="UI_RetractCashFail"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_SetWithdrawalResultSuccess"/>
      <Forward event="OnHardwareError" targetID="ID_SetWithdrawalResultError"/>
      <Forward event="OnFail" targetID="ID_SetWithdrawalResultError"/>
    </VTMPresentCash>



    <End ID="9999" comment="End">
    </End>

    <SetData ID="ID_SetWithdrawalResultSuccess" saveBuffer="{CounterService_WithdrawalResult,0}" value="0">
      <Forward event="OnConfirm" targetID="9999"/>
    </SetData>

    <SetData ID="ID_SetWithdrawalResultError" saveBuffer="{CounterService_WithdrawalResult,0}" value="-1">
      <Forward event="OnConfirm" targetID="9999"/>
    </SetData>

    <SetData ID="ID_SetWithdrawalResultCancel" saveBuffer="{CounterService_WithdrawalResult,0}" value="-2">
      <DefaultForward targetID="9999" />
    </SetData>

  </Activities>
  <DefaultForward>
    <Forward event="OnCancel" targetID="ID_SetWithdrawalResultCancel"/>
    <Forward event="OnTimeout" targetID="ID_SetWithdrawalResultError"/>
    <Forward event="OnKeyError" targetID="ID_SetWithdrawalResultError"/>
    <Forward event="OnHardwareError" targetID="ID_SetWithdrawalResultError"/>
  </DefaultForward>
</Workflow>
