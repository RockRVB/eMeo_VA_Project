<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="CloseTrans">
  <Head type="GRGWorkflow" author="HXL" timeStamp="2012/04/12 19:15:12" comment="The workflow design is for closing transaction"/>
  <DataPool>
  </DataPool>
  <Activities>
    <Start ID="0" comment="Start" shield="0" videoarea="false" homeVisible="0" callVisible="0" endflag="0">
      <Forward event="OnConfirm" targetID="ID_HandleSessionData"/>
    </Start>
	<HandleSessionData ID="ID_HandleSessionData"  UI="UI_thank_you" timeout="20000">
      <Forward event="OnContinue" targetID="ID_CompareVideoStatus"/>
    </HandleSessionData>
	<!--Check Agin Video Connection-->
	<!-- 判断视频状态 -->
    <!-- STATUS_END = 0,        未初始化前的状态，登陆前状态  -->
    <!-- STATUS_INITIAL_REQ,    初始化请求状态, 登陆中状态  -->
    <!-- STATUS_IDLE,           初始化成功后还未呼叫时的空闲状态  -->
    <!-- STATUS_CALL_REQ,       呼叫发起请求状态  -->
    <!-- STATUS_IN_TALKING,     通话中状态  -->
    <!-- STATUS_RELEASE_REQ,    呼叫发起释放状态  -->
    <!-- STATUS_ENDING_REQ,     发起结束初始化状态  -->
    <!-- STATUS_ANSWER_REQ,     应答中，此时点击应答，等有TALKING事件上报后，将迁移到STATUS_IN_TALKING  -->
    <!-- STATUS_IN_CALLING,     正在 来电中， 也就是收到振铃事件；对于AVAYA，主叫会收到振铃事件但被叫反而不会收到振铃事件  -->
    <!-- STATUS_IN_REJECTING,   正在拒绝中  -->
    <!-- STATUS_NETWORK_ERROR,  网络故障  -->
    <CompareData ID="ID_CompareVideoStatus" comment="" compareBuffer="{VTM_VideoStatusWrapper}">
      <Forward event="OnEqualSTATUS_IN_TALKING" targetID="ID_EndTransaction" />
      <DefaultForward targetID="ID_CompareReturnCardFlag" />
    </CompareData>
	
    <EndTransaction ID="ID_EndTransaction"  UI="UI_thank_you" timeout="20000">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_CompareReturnCardFlag"/>
    </EndTransaction>

    <CompareData ID="ID_CompareReturnCardFlag" comment="是否设置强制吞卡标志位" compareBuffer="{VTM_DebitReturnCardFlag}">
      <Forward event="OnEqualTrue" targetID="ID_SetDispenseCardData"/>
      <DefaultForward targetID="ID_CloseTransaction"/>
    </CompareData>

    <SetData ID="ID_SetDispenseCardData" saveBuffer="{VTM_DebitReturnCardFlag}" value="False">
      <Forward event="OnConfirm" targetID="ID_CloseTransactionReturnCard"/>
    </SetData>

    <CloseTransEx ID="ID_CloseTransactionReturnCard" UI="UI_waiting" comment="Close transaction" forceCaptureCardAndReason="1" digitalVoiceKey="|||||||||audio_017|">
      <States>
        <State name="TakeCard" UI="UI_take_card"/>
        <State name="TransTimeOut" UI="UI_timeout"/>
        <State name="KeyError" UI="UI_general_error"/>
        <State name="InvalidCard" UI="UI_invalid_card"/>
        <State name="HardwareError" UI="UI_hardware_error"/>
        <State name="GeneralError" UI="UI_general_error"/>
        <State name="CapturingCard" UI="UI_waiting"/>
        <State name="CaptureCardForTimeout" UI="UI_waiting"/>
        <State name="CaptureCard" UI="UI_waiting"/>
        <State name="ThankYou" UI="UI_thank_you"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_InvokeMainWorkflow"/>
      <Forward event="OnCaptureCard" targetID="ID_GetDevStatus"/>
    </CloseTransEx>

    <CloseTransEx ID="ID_CloseTransaction" UI="UI_waiting" comment="Close transaction" digitalVoiceKey="|||||||||audio_017|">
      <States>
        <State name="TakeCard" UI="UI_TakeCard"/>
        <State name="TransTimeOut" UI="UI_timeout"/>
        <State name="KeyError" UI="UI_general_error"/>
        <State name="InvalidCard" UI="UI_invalid_card"/>
        <State name="HardwareError" UI="UI_hardware_error"/>
        <State name="GeneralError" UI="UI_general_error"/>
        <State name="CapturingCard" UI="UI_waiting"/>
        <State name="CaptureCardForTimeout" UI="UI_waiting"/>
        <State name="CaptureCard" UI="UI_waiting"/>
        <State name="ThankYou" UI="UI_thank_you"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_InvokeMainWorkflow"/>
      <Forward event="OnCaptureCard" targetID="ID_GetDevStatus"/>
    </CloseTransEx>

    <GetDevStatus ID="ID_GetDevStatus" comment="Get device status" devType="RPTR">
      <Forward event="OnNormal" targetID="ID_PrintReceipt"/>
      <Forward event="OnWarn" targetID="ID_PrintReceipt"/>
      <Forward event="OnFail" targetID="ID_InvokeMainWorkflow"/>
    </GetDevStatus>
    <PrintReceipt ID="ID_PrintReceipt" UI="UI_PrintingReceipt" formName="" showTime="2000">
      <States>
        <State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
        <State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_InvokeMainWorkflow"/>
    </PrintReceipt>
    <InvokeWorkflow ID="ID_InvokeMainWorkflow" name="Main" comment="Invoke main workflow" syn="0">
      <Forward event="OnConfirm" targetID="9999"/>
    </InvokeWorkflow>
    <End ID="9999" comment="End">
    </End>
  </Activities>
</Workflow>
