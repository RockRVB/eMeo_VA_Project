<?xml version="1.0" encoding="utf-8"?>
<Workflow name="NoCardDeposit">
	<Head type="GRGWorkflow" author="HXL" timeStamp="2012/04/12 19:15:12" comment="The workflow design is for no card deposit"/>
	<DataPool>
	</DataPool>
	<Activities>
		<Start ID="0" comment="Start">
			<Forward event="OnConfirm" targetID="ID_InputNoCardDepositAccount"/>
		</Start>
		<InputInfo ID="ID_InputNoCardDepositAccount" UI="UI_InputNoCardDepositAccount" comment="Input no card deposit account" minLen="16" maxLen="19" isCardInsertFlag="1">
			<Forward event="OnConfirm" targetID="ID_RequestTrans"/>
		</InputInfo>
		<RequestTrans ID="ID_RequestTrans" UI="UI_RequestTrans" comment="ADI request">
			<States>
				<State name="PackFail" UI="UI_GeneralError"/>
				<State name="ConnectFail" UI="UI_GeneralError"/>
				<State name="SendFail" UI="UI_GeneralError"/>
				<State name="ReceiveFail" UI="UI_GeneralError"/>
				<State name="ReceiveTimeout" UI="UI_GeneralError"/>
				<State name="NetworkFail" UI="UI_GeneralError"/>
				<State name="UnpackFail" UI="UI_GeneralError"/>
				<State name="HardwareError" UI="UI_GeneralError"/>
				<State name="TransNotAccepted" UI="UI_ICTransNotAccepted"/>
				<State name="TransDeclined" UI="UI_ICTransDeclined"/>
				<State name="TransTerminated" UI="UI_ICTransTerminated"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_ShowAccountInfo"/>
			<Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
			<Forward event="OnReInputPin" targetID="ID_HostRefuse"/>
		</RequestTrans>
		<SelectFunction ID="ID_ShowAccountInfo" UI="UI_ShowAccountInfo" comment="Show transfer Info">
			<Forward event="OnConfirm" targetID="ID_InvokeDepositWorkflow"/>
		</SelectFunction>
		<!--主机拒绝，显示拒绝码对应的提示信息，然后退卡-->
		<Prompt ID="ID_HostRefuse" UI="UI_HostRefuse" timeout="5000" comment="show host refuse">
			<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
		</Prompt>
		<InvokeWorkflow ID="ID_InvokeDepositWorkflow" name="Deposit" comment="Invoke deposit workflow">
			<Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow"/>
		</InvokeWorkflow>
		<InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" name="CloseTrans" comment="Invoke close trans workflow">
			<Forward event="OnConfirm" targetID="9999"/>
		</InvokeWorkflow>
		<End ID="9999" comment="End">
		</End>
	</Activities>
	<DefaultForward>
		<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnKeyError" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
	</DefaultForward>
</Workflow>
