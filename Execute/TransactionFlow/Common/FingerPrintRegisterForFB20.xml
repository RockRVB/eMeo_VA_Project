<?xml version="1.0"?>
<Workflow name="FingerPrintRegisterForFB20">
  <Head type="GRGWorkflow" author="Alson" timeStamp="" comment="" />
  <DataPool />
  <Activities>
    <Start ID="0" UI="" comment="Start">
      <Forward event="OnConfirm" targetID="ID_GetPublicKey" />
    </Start>
	<RequestTransViaRestful ID="ID_GetPublicKey" UI="UI_CommonProcessing" digitalVoiceKey="||||||||" transType="GetPublicKey"  transFormat="json">
		  <States>
			<State name="PackFail" UI="UI_general_error"/>
			<State name="ConnectFail" UI="UI_general_error"/>
			<State name="SendFail" UI="UI_general_error"/>
			<State name="ReceiveFail" UI="UI_general_error"/>
			<State name="ReceiveTimeout" UI="UI_general_error"/>
			<State name="NetworkFail" UI="UI_general_error"/>
			<State name="UnpackFail" UI="UI_general_error"/>
			<State name="HardwareError" UI="UI_general_error"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_UserLoginFB"/>
		  <Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
	</RequestTransViaRestful>
	<UserLoginFB ID="ID_UserLoginFB" UI="" comment="" timeout="60000" >
		  <Forward event="OnConfirm" targetID="ID_FBLOGINRequest" />
		  <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
	</UserLoginFB>
	<RequestTransViaRestful ID="ID_FBLOGINRequest" UI="UI_CommonProcessing" digitalVoiceKey="||||||||" transType="FB20LOGIN"  transFormat="json">
	      <States>
			<State name="PackFail" UI="UI_general_error"/>
			<State name="ConnectFail" UI="UI_general_error"/>
			<State name="SendFail" UI="UI_general_error"/>
			<State name="ReceiveFail" UI="UI_general_error"/>
			<State name="ReceiveTimeout" UI="UI_general_error"/>
			<State name="NetworkFail" UI="UI_general_error"/>
			<State name="UnpackFail" UI="UI_general_error"/>
			<State name="HardwareError" UI="UI_general_error"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_FBLoginResult"/>
		  <Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
		</RequestTransViaRestful>
		<FBLoginResult ID="ID_FBLoginResult" UI="" comment="" timeout="60000" >
		  <Forward event="OnConfirm" targetID="ID_FingerInputCifToMatch" />
		  <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
		</FBLoginResult>
		<InputIdNumberFB ID="ID_FingerInputCifToMatch" UI="UI_InputFaceRegisterInfo" digitalVoiceKey="action_034" comment="cannot print receipt">
			<Forward event="OnConfirm" targetID="ID_GetCustomerInfo"/>
			<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		</InputIdNumberFB>
		<RequestTransViaRestful ID="ID_GetCustomerInfo" UI="UI_CommonProcessing" digitalVoiceKey="||||||||" transType="FB20GetCustomerInfo"  transFormat="json">
		  <States>
			<State name="PackFail" UI="UI_general_error"/>
			<State name="ConnectFail" UI="UI_general_error"/>
			<State name="SendFail" UI="UI_general_error"/>
			<State name="ReceiveFail" UI="UI_general_error"/>
			<State name="ReceiveTimeout" UI="UI_general_error"/>
			<State name="NetworkFail" UI="UI_general_error"/>
			<State name="UnpackFail" UI="UI_general_error"/>
			<State name="HardwareError" UI="UI_general_error"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_GetCustomerInfoResultFB"/>
		  <Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
		</RequestTransViaRestful>
		<GetCustomerInfoResultFB20 ID="ID_GetCustomerInfoResultFB"  comment="" timeout="300000" >
		  <Forward event="OnConfirm" targetID="ID_FingerprintScan" />
		  <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
		</GetCustomerInfoResultFB20>
		<FingerprintCreateTemplateFB ID="ID_FingerprintScan" UI="UI_FingerEnroll" digitalVoiceKey="action_044|action_043" comment="" timeout="30000">
			<States>
				<State name="FingerError" UI="UI_FingerShowError"/>
			</States>
			<Forward event="OnContinue" targetID="ID_FingerRegister"/>
			<Forward event="OnFail" targetID="ID_FingerShowError"/>
			<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
			<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
		</FingerprintCreateTemplateFB>
		<RequestTransViaRestful ID="ID_FingerRegister" UI="UI_CommonProcessing" digitalVoiceKey="||||||||" transType="FB20FingerprintRegister"  transFormat="json">
		  <States>
			<State name="PackFail" UI="UI_general_error"/>
			<State name="ConnectFail" UI="UI_general_error"/>
			<State name="SendFail" UI="UI_general_error"/>
			<State name="ReceiveFail" UI="UI_general_error"/>
			<State name="ReceiveTimeout" UI="UI_general_error"/>
			<State name="NetworkFail" UI="UI_general_error"/>
			<State name="UnpackFail" UI="UI_general_error"/>
			<State name="HardwareError" UI="UI_general_error"/>
		  </States>
		  <Forward event="OnConfirm" targetID="ID_FingerShowSuccess"/>
		  <Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
		  <Forward event="OnHostRefuse" targetID="ID_FingerShowError"/>
		</RequestTransViaRestful>
		<Prompt ID="ID_FingerShowError" UI="UI_FingerShowError" digitalVoiceKey="action_044" comment="" timeout="5000">
          <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow" />
		  <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
        </Prompt>
		
		<Prompt ID="ID_FingerShowNotRegister" UI="UI_FingerShowNotRegister" digitalVoiceKey="action_045" comment="" timeout="5000">
          <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow" />
		  <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
        </Prompt>
		
		<Prompt ID="ID_FingerShowNotMatch" UI="UI_FingerShowNotMatch" digitalVoiceKey="action_042" comment="" timeout="5000">
          <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow" />
		  <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
        </Prompt>
		
		<Prompt ID="ID_FingerShowSuccess" UI="UI_FingerShowSuccess" digitalVoiceKey="action_041" comment="" timeout="5000">
          <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow" />
		  <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
        </Prompt>
	
    <End ID="9999" UI="" comment="End" />
    <InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" UI="" comment="Invoke close trans workflow" name="CloseTrans">
      <Forward event="OnConfirm" targetID="9999" />
    </InvokeWorkflow>
	<InvokeWorkflow ID="ID_HostRefuse" UI="" comment="Invoke close trans workflow" name="CloseTrans">
      <Forward event="OnConfirm" targetID="9999" />
    </InvokeWorkflow>
  </Activities>
  <DefaultForward>
    <Forward event="OnHardwareError" targetID="ID_DevError" />
    <Forward event="OnFail" targetID="ID_EventError" />
    <Forward event="OnTimeout" targetID="ID_GoTimeOut" />
    <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
  </DefaultForward>
</Workflow>