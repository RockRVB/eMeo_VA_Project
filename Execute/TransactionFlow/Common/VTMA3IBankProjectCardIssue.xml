<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="VTMA3IBankProjectCardIssue">
  <Head type="GRGWorkflow" author="" timeStamp="" comment="The workflow design is for Card printing Demo"/>
  <DataPool>
  </DataPool>
  <Activities>
    <Start ID="0" comment="Start" callVisible="0" endflag="1">
      <Forward event="OnConfirm" targetID="ID_DispenseCardGetDevStatusEx"/>
    </Start>

    <!--Check 发卡机 -->
    <GetDevStatus ID="ID_DispenseCardGetDevStatusEx" UI="UI_waiting" digitalVoiceKey="|" comment="Get device status" devType="CRD">
      <States>
        <State name="GetDevStatusExError" UI="UI_hardware_error"></State>
      </States>
      <Forward event="OnNormal" targetID="ID_IDCReadGetDevStatusEx"/>
      <Forward event="OnWarn" targetID="ID_IDCReadGetDevStatusEx"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </GetDevStatus>

    <!--Check 读卡器 -->
    <GetDevStatus ID="ID_IDCReadGetDevStatusEx" UI="UI_waiting" digitalVoiceKey="|" comment="Get device status" devType="CRDIDC" eject="1">
      <States>
        <State name="GetDevStatusExError" UI="UI_hardware_error"></State>
      </States>	
      <Forward event="OnNormal" targetID="ID_SetUserModeType"/>
      <Forward event="OnWarn" targetID="ID_SetTransTypeNewCard"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </GetDevStatus>
	
	<SetData ID="ID_SetUserModeType" saveBuffer="{VTMA.send.CallRemoteTeller.userModeType,0}" value="1">
		<Forward event="OnConfirm" targetID="ID_SetTransTypeNewCard"/>
	</SetData>

	<SetData ID="ID_SetTransTypeNewCard" saveBuffer="{VTM_TransTypeName,0}" value="VTM_Standard_NewCard">
      <Forward event="OnConfirm" targetID="ID_SetTransValue"/>
    </SetData>
	
	<SetData ID="ID_SetTransValue" saveBuffer="{VTMA.send.CallRemoteTeller.args.businessInfo.transaction,0}" value="1">
      <Forward event="OnConfirm" targetID="ID_CompareVideoStatus"/>
    </SetData>
	
	<!--Check Agin Video Connection-->
	<!-- 判断视频状态 -->
    <!-- STATUS_END = 0,        未初始化前的状态，登陆前状态  -->
    <!-- STATUS_INITIAL_REQ,    初始化请求状态, 登陆中状态  -->
    <!-- STATUS_IDLE,           初始化成功后还未呼叫时的空闲状态  -->
    <!-- STATUS_CALL_REQ,       呼叫发起请求状态  -->
    <!-- STATUS_IN_TALKING,     通话中状态  -->
    <!-- STATUS_RELEASE_REQ,    呼叫发起释放状态  -->
    <!-- STATUS_ENDING_REQ,     发起结束初始化状态  -->
    <!-- STATUS_ANSWER_REQ,     应答中，此时点击应答，等有TALKING事件上报后，将迁移到STATUS_IN_TALKING  -->
    <!-- STATUS_IN_CALLING,     正在 来电中， 也就是收到振铃事件；对于AVAYA，主叫会收到振铃事件但被叫反而不会收到振铃事件  -->
    <!-- STATUS_IN_REJECTING,   正在拒绝中  -->
    <!-- STATUS_NETWORK_ERROR,  网络故障  -->
    <CompareData ID="ID_CompareVideoStatus" comment="" compareBuffer="{VTM_VideoStatusWrapper}">
      <Forward event="OnEqualSTATUS_IN_TALKING" targetID="ID_ChangeBusiness" />
      <Forward event="OnEqualSTATUS_IDLE" targetID="ID_InvokeCallAgentWorkflow" />
      <DefaultForward targetID="ID_ConnectAgentFail" />
    </CompareData>

  	<VTMARequestTransViaRestful ID="ID_ChangeBusiness" UI="UI_waiting" digitalVoiceKey="" transType="ChangeBusiness" transFormat="json" msgTimeout="2000">	
      <Forward event="OnContinue" targetID="ID_SendFlowCardProtocol"/>
      <DefaultForward targetID="ID_SendFlowCardProtocol" />
	</VTMARequestTransViaRestful>
	
	<VTMAActBusinessFlow ID="ID_SendFlowCardProtocol" UI="" CurrentStep="readAgreement" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_CardProtol" />
    </VTMAActBusinessFlow>
	
    <!-- Invoke the Authorization workflow-->
    <InvokeWorkflow ID="ID_InvokeCallAgentWorkflow" name="VTMA3CallAgent" comment="Invoke CallAgent workflow" index="0">
      <Forward event="OnConfirm" targetID="ID_CompareVideoStatusAgain"/>
    </InvokeWorkflow>	
	
	<!-- Judge whether the agent is connected or not -->
	  <CompareData ID="ID_CompareVideoStatusAgain" comment="" compareBuffer="{VTM_VideoStatusWrapper}"> 
      <Forward event="OnEqualSTATUS_IN_TALKING" targetID="ID_ChangeBusiness" />
      <DefaultForward targetID="ID_ConnectAgentFail" />
    </CompareData>
	
    <BeginTransaction ID="ID_BeginTransaction" UI="UI_contacting_agent" digitalVoiceKey="|action_010" timeout="60000">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
        <State name="TimeOutError" UI="UI_timeout"/>
      </States>
      <Forward event="OnContinue" targetID="ID_CardProtol"/>
      <Forward event="OnFail" targetID="ID_ConnectAgentFail"/>
    </BeginTransaction>

    <!--view CardProtol-->
    <VTMSelectFunction ID="ID_CardProtol" UI="UI_card_protocol" digitalVoiceKey="action_011" timeout="120000" homeVisible="1" index="2">
      <!--<Forward event="OnConfirm" targetID="ID_IDCardGetDevStatusEx"/>-->
      <Forward event="OnConfirm" targetID="ID_ScanByPassportGetDevStatusEx"/>
	  <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMSelectFunction>
	
    <GetDevStatusEx ID="ID_ScanByCAMGetDevStatusEx" UI="" comment="Get device status" devType="CAM" callVisible="0">
      <States>
        <State name="GetDevStatusExError" UI="UI_DevError" />
      </States>
      <Forward event="OnNormal" targetID="ID_SelectIDcard" />
      <Forward event="OnWarn" targetID="ID_SelectIDcard" />
      <Forward event="OnFail" targetID="ID_ScanByPassportGetDevStatusEx" />
    </GetDevStatusEx>
	<GetDevStatusEx ID="ID_ScanByPassportGetDevStatusEx" UI="UI_waiting" digitalVoiceKey="|" comment="Get device status" devType="PassportScaner" callVisible="0">
      <States>
        <State name="GetDevStatusExError" UI="UI_general_error" />
      </States>
      <Forward event="OnNormal" targetID="ID_SendFlowPassportScan" />
      <Forward event="OnWarn" targetID="ID_SendFlowPassportScan" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </GetDevStatusEx>
	
	<VTMAActBusinessFlow ID="ID_SendFlowPassportScan" UI="" CurrentStep="scanPassport" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_ScanPassportByScanner" />
    </VTMAActBusinessFlow>
	
	<SelectIDType ID="ID_SelectIDcard" UI="UI_SelectIDcard" digitalVoiceKey="action_012" comment="" timeout="300000" >
      <!-- <Forward event="OnCCCD" targetID="ID_ReadCitizenIDCardGetDevStatusEx" /> -->
      <Forward event="OnIdCard" targetID="ID_ScanIDCardGetDevStatusEx" />
      <Forward event="OnPassport" targetID="ID_ScanPassPortGetDevStatusEx" />
    </SelectIDType>
	<GetDevStatusEx ID="ID_ScanIDCardGetDevStatusEx" UI="" comment="Get device status" devType="CAM" callVisible="0">
      <States>
        <State name="GetDevStatusExError" UI="UI_DevError" />
      </States>
      <Forward event="OnNormal" targetID="ID_PutIDCardIntoHighCamera" />
      <Forward event="OnWarn" targetID="ID_PutIDCardIntoHighCamera" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </GetDevStatusEx>
    <WaitSleep ID="ID_PutIDCardIntoHighCamera" UI="UI_PutIDCardIntoHighCamera" comment="" timeout="5000" >
	 <DefaultUIStates>
		<State name="SavingAccountMainFlow" UI="UI_PutIDCardtoCameraSavingAccount"/>
		<State name="DepositByIDToOwner" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOnUsAccount" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOffUsAccount" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOnUsCard" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOffUsCard" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="MaintenanceMainWorkflow" UI="UI_PutIDCardIntoHighCameraMaintenanceMainWorkflow"/>
		<State name="CompleKYCMainFlow" UI="UI_KYCInsertIDCard"/>
		<State name="BillingMainFlow" UI="UI_BillingInsertOldIDCard"/>
		<State name="Withdrawal" UI="UI_WithdrawalInsertOldIDCard"/>
		<State name="TransferMainFlow" UI="UI_TransferInsertOldIDCard"/>
		<State name="PassbookSettleMainFlow" UI="UI_PassbookInsertOldIDCard"/>
		<State name="FingerprintMaintenanceMainFlow" UI="UI_FingerprintMaintainInsertOldIDCard"/>
	  </DefaultUIStates>
      <Forward event="OnContinue" targetID="ID_ScanOldIDCard" />
    </WaitSleep>
    <ScanDoc ID="ID_ScanOldIDCard" UI="UI_ScanIDCard" digitalVoiceKey="|action_013" comment="" CX="460" CY="624" CW="572" CH="808" windowx="140"  IsIDCard="1" windowy="325" windowwidth="480" windowheight="400" defaulnum="2" timeout="300000" callVisible="0" >
      <States>
        <State name="OpenScanDocError" UI="UI_DevError" />
        <State name="StartTakePick" UI="UI_ScanIDCard" />
      </States>
	  <DefaultUIStates>
		<State name="SavingAccountMainFlow" UI="UI_ScanIDCardSavingAccount"/>
		<State name="DepositByIDToOwner" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOnUsAccount" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOffUsAccount" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOnUsCard" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOffUsCard" UI="UI_ScanIDCardDeposit"/>
		<State name="MaintenanceMainWorkflow" UI="UI_ScanIDCardMaintenanceMainWorkflow"/>
		<State name="CompleKYCMainFlow" UI="UI_KYCScanIDCard"/>
		<State name="BillingMainFlow" UI="UI_BillingScanIDCard"/>
		<State name="Withdrawal" UI="UI_WithdrawalScanIDCard"/>
		<State name="TransferMainFlow" UI="UI_TransferScanIDCard"/>
		<State name="PassbookSettleMainFlow" UI="UI_PassbookScanIDCard"/>
		<State name="FingerprintMaintenanceMainFlow" UI="UI_FingerprintMaintainScanIDCard"/>
	  </DefaultUIStates>
	  <!--
      <Forward event="OnContinue" targetID="ID_UpFileIDCardFront" /> -->
	  <Forward event="OnContinue" targetID="ID_IDcardInfo" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </ScanDoc>
	
	<!--護照模塊更換身份證模塊 -->
	<!-- Get device status of ID card reader -->
	<GetDevStatusEx ID="ID_IDCardGetDevStatusEx" UI="UI_Waiting" comment="Get device status" devType="IDReader" callVisible="0" homeVisible="0">
	  <States>
        <State name="GetDevStatusExError" UI="UI_DevError"/>
      </States>
      <Forward event="OnNormal" targetID="ID_ScanIDCard" />
      <Forward event="OnWarn" targetID="ID_SetLoginFlagFalse" />
      <Forward event="OnFail" targetID="9999" />
    </GetDevStatusEx>
	
	<!-- Scan ID card -->
		<!-- 扫描身份证 -->
		<ScanIDCard ID="ID_ScanIDCard" UI="UI_insert_passport4IssueCard" CallingMethodType="1" homeVisible="1" generateImg="1">
			<States>
				<State name="IDCardError" UI="UI_ReadingIDCardError"/>
				<State name="OutDateError" UI="UI_IDCardOutDate"/>
				<State name="TakeIDCard" UI="UI_TakeIdCard"/>
				<State name="ReadingCard" UI="UI_IDReadingCard"/>
			</States>
			<Forward event="OnContinue" targetID="ID_IDInfo"/>
			<Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		</ScanIDCard>

	<VTMACommonVerify ID="ID_IDInfo" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="IDCardInfo">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SendFlowFillForm"/>
	  <Forward event="OnTryAgain" targetID="ID_ScanIDCard"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>
	
	
	<VTMACommonVerify  ID="ID_IDcardInfo" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="CheckIDCardImage">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_FillFormPassport"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>
	<GetDevStatusEx ID="ID_ScanPassPortGetDevStatusEx" UI="" comment="Get device status" devType="CAM" callVisible="0">
      <States>
        <State name="GetDevStatusExError" UI="UI_DevError" />
      </States>
      <Forward event="OnNormal" targetID="ID_PutPassPortIntoHighCamera" />
      <Forward event="OnWarn" targetID="ID_PutPassPortIntoHighCamera" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </GetDevStatusEx>
    <WaitSleep ID="ID_PutPassPortIntoHighCamera" UI="UI_PutIDCardIntoHighCamera" comment="" timeout="5000" >
	 <DefaultUIStates>
		<State name="SavingAccountMainFlow" UI="UI_PutIDCardtoCameraSavingAccount"/>
		<State name="DepositByIDToOwner" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOnUsAccount" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOffUsAccount" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOnUsCard" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="DepositIDOffUsCard" UI="UI_PutIDCardIntoHighCameraDeposit"/>
		<State name="MaintenanceMainWorkflow" UI="UI_PutIDCardIntoHighCameraMaintenanceMainWorkflow"/>
		<State name="CompleKYCMainFlow" UI="UI_KYCPutPassportIntoHighCamera"/>
		<State name="BillingMainFlow" UI="UI_BillingInsertOldIDCard"/>
		<State name="Withdrawal" UI="UI_WithdrawalInsertPassport"/>
		<State name="TransferMainFlow" UI="UI_TransferInsertPassport"/>
		<State name="PassbookSettleMainFlow" UI="UI_PassbookInsertOldIDCard"/>
		<State name="FingerprintMaintenanceMainFlow" UI="UI_FingerprintMaintainInsertOldIDCard"/>
	  </DefaultUIStates>
      <Forward event="OnContinue" targetID="ID_ScanPassPort" />
    </WaitSleep>
    <ScanDoc ID="ID_ScanPassPort" UI="UI_ScanPassport" digitalVoiceKey="|action_015" comment="" windowx="140" windowy="325" IsIDCard="2" homeVisible="1" windowwidth="480" windowheight="400" defaulnum="1" timeout="300000" callVisible="0" >
      <States>
        <State name="OpenScanDocError" UI="UI_DevError" />
        <State name="StartTakePick" UI="UI_ScanPassport" />
      </States>
	   <DefaultUIStates>
		<State name="SavingAccountMainFlow" UI="UI_ScanIDCardSavingAccount"/>
		<State name="DepositByIDToOwner" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOnUsAccount" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOffUsAccount" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOnUsCard" UI="UI_ScanIDCardDeposit"/>
		<State name="DepositIDOffUsCard" UI="UI_ScanIDCardDeposit"/>
		<State name="MaintenanceMainWorkflow" UI="UI_ScanIDCardMaintenanceMainWorkflow"/>
		<State name="CompleKYCMainFlow" UI="UI_KYCScanIDCard"/>
		<State name="BillingMainFlow" UI="UI_BillingScanIDCard"/>
		<State name="Withdrawal" UI="UI_WithdrawalScanIDCard"/>
		<State name="TransferMainFlow" UI="UI_TransferScanIDCard"/>
		<State name="PassbookSettleMainFlow" UI="UI_PassbookScanIDCard"/>
		<State name="FingerprintMaintenanceMainFlow" UI="UI_FingerprintMaintainIDCard"/>
	  </DefaultUIStates>
      <Forward event="OnContinue" targetID="ID_SetScanDataPassport" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </ScanDoc>
    <SetScanData ID="ID_SetScanDataPassport" UI="" comment="" callVisible="0">
      <Forward event="OnContinue" targetID="ID_ScanPassportInfo" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </SetScanData>
	<VTMACommonVerify ID="ID_ScanPassportInfo" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="CheckPassportImage">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_FillFormPassport"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>
    <PassportScan  ID="ID_ScanPassportByScanner" UI="UI_insert_passport4IssueCard" digitalVoiceKey="||||action_015" CallingMethodType="0" manualScan="0" homeVisible="0" timeout="30000">
      <States>
        <State name="TakePassport" UI="UI_take_passport4IssueCard" />
        <State name="ScanningPassport" UI="UI_reading_passport" />
		    <State name="ScanError" UI="UI_scan_passport_failure" />
        <State name="HardwareError" UI="UI_hardware_error" />
      </States>
      <Forward event="OnContinue" targetID="ID_PassportInfo" />
      <Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow" />
      <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
      <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />	  
      <Forward event="OnFail" targetID="ID_ScanPassportAgain" />
    </PassportScan>
	
	<Prompt ID="ID_ScanPassportAgain" UI="UI_ScanPassportAgain" digitalVoiceKey="action_016" timeout="60000" comment="">
	  <Forward event="OnConfirm" targetID="ID_ScanPassportByScanner" />
      <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow" />
	  <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
    </Prompt>

    <VTMACommonVerify ID="ID_PassportInfo" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="PassportInfo">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SendFlowFillForm"/>
	  <Forward event="OnTryAgain" targetID="ID_ScanPassportByScanner"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>
	
	<VTMAActBusinessFlow ID="ID_SendFlowFillForm" UI="" CurrentStep="customerInfo" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_FillFormPassport" />
    </VTMAActBusinessFlow>
	
    <!--Fill in the Passport Form-->
    <FillFormPassport ID="ID_FillFormPassport" UI="UI_input_form_passport4IssueCard" digitalVoiceKey="action_017" timeout="120000">
      <Forward event="OnConfirm" targetID="ID_PassportFormInfoCheck"/>
	    <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow" />
    </FillFormPassport>

    <!--填单信息审核请求-->
    <VTMACommonVerify ID="ID_PassportFormInfoCheck" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="PassportFormData">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SendFlowSignature"/>
      <Forward event="OnTryAgain" targetID="ID_FillFormPassport"/>	  
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>
	
	<VTMAActBusinessFlow ID="ID_SendFlowSignature" UI="" CurrentStep="sign" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_Signature" />
    </VTMAActBusinessFlow>

    <!--  电子签名-->
    <ConfirmSignInfo4Html ID="ID_Signature" UI="UI_sign_atPad4IssueCard" digitalVoiceKey="|||action_018" timeout="60000">
      <States>
        <State name="NetWorkError" UI="UI_network_error" />
        <State name="TimeOutError" UI="UI_timeout" />
        <State name="ServiceCloseTrans" UI="UI_host_refuse" />
      </States>
      <Forward event="OnContinue" targetID="ID_RequestSignCheck" />
      <Forward event="OnReInput" targetID="ID_Signature" />
      <Forward event="OnExitEx" targetID="ID_InvokeCloseTransWorkflow" />
    </ConfirmSignInfo4Html>

    <VTMACommonVerify ID="ID_RequestSignCheck" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="SignatureCheck">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_GetQRCodeFac"/>
      <Forward event="OnTryAgain" targetID="ID_Signature"/>	  
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>

    <QRCodeFac ID="ID_GetQRCodeFac" UI="" comment="" barw="270" barh="70" qrw="130" qrh="130" homeVisible="0">
      <Forward event="OnContinue" targetID="ID_GenerateDitCarForm" />
      <Forward event="OnFail" targetID="ID_SetReturnResult" />
    </QRCodeFac>
	
    <GenerateDebitCardForm ID="ID_GenerateDitCarForm" UI="" comment="">
      <Forward event="OnContinue" targetID="ID_GetPrinterStatusEx" />
      <Forward event="OnFail" targetID="ID_SetReturnResult" />
    </GenerateDebitCardForm>
	
    <GetDevStatus ID="ID_GetPrinterStatusEx" UI="" comment="Get device status" devType="DocPrinter" callVisible="0">
      <States>
        <State name="GetDevStatusExError" UI="UI_hardware_error" />
      </States>
      <Forward event="OnNormal" targetID="ID_SendFlowPrintSignature" />
      <Forward event="OnWarn" targetID="ID_PrintFormData" />
      <Forward event="OnFail" targetID="ID_SetReturnResult" />
    </GetDevStatus>
	
	<VTMAActBusinessFlow ID="ID_SendFlowPrintSignature" UI="" CurrentStep="printSign" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_PrintFormData" />
    </VTMAActBusinessFlow>
	
    <PrintFormData ID="ID_PrintFormData" UI="UI_printing_form4IssueCard" digitalVoiceKey="|action_019" comment="" ids="IDS_AcPrint" fileWithStamp="0" fileName="iBankProjectCardApply.html" timeout="120000">
      <States>
        <State name="PrintFormDataError" UI="UI_hardware_error" />
      </States>
	    <DefaultUIStates>
		<State name="CreateSavingAccount" UI="UI_PrintFormSavingAccount"/>
		<State name="DepositMainFlow" UI="UI_SignFormDeposit"/>
		<State name="saving_with_card" UI="UI_PrintFormSavingAccounwithcard"/>
	  </DefaultUIStates>
      <Forward event="OnContinue" targetID="ID_SendFlowRetractPaper" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </PrintFormData>
	
	<VTMAActBusinessFlow ID="ID_SendFlowRetractPaper" UI="" CurrentStep="scanSign" FlowStatus="99" timeout="50000">
      <!-- <DefaultForward targetID="ID_SetIsNeedChecker" /> -->
      <DefaultForward targetID="ID_StartFeed" />
    </VTMAActBusinessFlow>
	
	<!-- A4扫描仪 -->
	<StartFeed ID="ID_StartFeed" UI="UI_scan_form4IssueCard" digitalVoiceKey="||||||action_020" comment="" feedimg="1" chkbar="0" timeout="120000" homeVisible="0">
      <States> 
        <State name="ScanFormSuccess" UI="UI_ScanFormSuccess"></State>
        <State name="CheckingQRCode" UI="UI_CheckingQRCode"></State>
        <State name="QRCodeEmptyOrIncorrect" UI="UI_QRCodeEmptyOrIncorrect"></State>
        <State name="StartFeedFailure" UI="UI_hardware_error"></State>
        <State name="ReStartFeed" UI="UI_RetractFormAgain"></State>
        <State name="TakePaper" UI="UI_TakeBackForm"></State>
      </States>
      <Forward event="OnContinue" targetID="ID_SetIsNeedChecker"/>
      <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnRePrint" targetID="ID_GetPrinterStatusEx"/>
      <Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
    </StartFeed> 
	<!-- 高拍仪 -->
	<!-- <ScanDocOperation4Exhibition ID="ID_StartFeed" UI="UI_ScanDoc" comment="" windowx="140" windowy="325" IsIDCard="0" windowwidth="480" windowheight="400" defaulnum="1" timeout="300000" index="4">
      <States>
        <State name="OpenScanDocError" UI="UI_hardware_error" />
        <State name="StartTakePick" UI="UI_ScanDoc" />
      </States>
      <Forward event="OnContinue" targetID="ID_SetIsNeedChecker" />
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow" />
    </ScanDocOperation4Exhibition> -->
	
	<SetData ID="ID_SetIsNeedChecker" saveBuffer="{VTMA.send.response.isNeedChecker}" value="1">
		  <!-- <Forward event="OnConfirm" targetID="ID_SendFlowprintingCard"/> -->
    	<Forward event="OnConfirm" targetID="ID_RequestFormCheck"/>
	</SetData>

    <VTMACommonVerify ID="ID_RequestFormCheck" UI="UI_info_review" digitalVoiceKey="|action_014" VerifyType="CheckForm">
      <States>
        <State name="NetWorkError" UI="UI_network_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SendFlowprintingCard"/>
	  <Forward event="OnTryAgain" targetID="ID_SendFlowPrintSignature"/>
      <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMACommonVerify>

    <RequestTransViaRestful ID="ID_RequestTransForAccNumber" UI="UI_waiting" digitalVoiceKey="||||||||" transType="registerAcc"  transFormat="json">
      <States>
        <State name="PackFail" UI="UI_general_error"/>
        <State name="ConnectFail" UI="UI_general_error"/>
        <State name="SendFail" UI="UI_general_error"/>
        <State name="ReceiveFail" UI="UI_general_error"/>
        <State name="ReceiveTimeout" UI="UI_general_error"/>
        <State name="NetworkFail" UI="UI_general_error"/>
        <State name="UnpackFail" UI="UI_general_error"/>
        <State name="HardwareError" UI="UI_general_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_DispenseCard"/>
      <Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnReceiveFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnReceiveTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnUnpackFail" targetID="ID_InvokeCloseTransWorkflow"/>
      <Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
    </RequestTransViaRestful>	
	
	<VTMAActBusinessFlow ID="ID_SendFlowprintingCard" UI="" CurrentStep="printingCard" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_DispenseCard" />
    </VTMAActBusinessFlow>

    <!--开始发卡-->
    <DispenseCard ID="ID_DispenseCard" UI="UI_dispense_card" digitalVoiceKey="|action_021" homeVisible="0">
      <States>
        <State name="DispenseCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SetDefaultCHN"/>
      <Forward event="OnHardwareError" targetID="ID_ReturnCard"/>
    </DispenseCard>
	<CRDReadRawDataProj ID="ID_ReadRawData" UI="UI_UCB_tip_Loading" homeVisible="0">
      <States>
        <State name="ReadRawDataError" UI="UI_hardware_error" />
      </States>
      <Forward event="OnContinue" targetID="ID_SetPersonAndNameonCard" />
      <Forward event="OnICType" targetID="ID_ICBuildAppList" />
      <Forward event="OnFail" targetID="ID_ReturnCardForHardwareError" />
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError" />
    </CRDReadRawDataProj>
    <ICBuildAppList ID="ID_ICBuildAppList" UI="UI_UCB_tip_Loading" homeVisible="0" comment="">
      <Forward event="OnOneApplication" targetID="ID_ICAppLoadedForFirstTime" />
      <Forward event="OnMoreApplication" targetID="ID_ICMoreAppSelectForFirstTime" />
      <Forward event="OnFallback" targetID="ID_ICGetTrack" />
      <Forward event="OnCancel" targetID="ID_ICTransCancel" />
    </ICBuildAppList>
    <ICAppLoaded ID="ID_ICAppLoadedForFirstTime" UI="UI_UCB_tip_Loading" homeVisible="0" comment="">
      <Forward event="OnConfirm" targetID="ID_ICGetTrack" />
      <Forward event="OnFallback" targetID="ID_ICGetTrack" />
      <Forward event="OnTryAgain" targetID="ID_ICMoreAppSelectForFirstTime" />
      <Forward event="OnICAppLoadedFail" targetID="ID_ICTransCancel" />
    </ICAppLoaded>
    <ICMoreAppSelect ID="ID_ICMoreAppSelectForFirstTime" UI="UI_ICMoreAppSelect" homeVisible="0" comment="">
      <Forward event="OnConfirm" targetID="ID_ICAppLoadedForFirstTime" />
    </ICMoreAppSelect>
    <Prompt ID="ID_ICTransCancel" UI="UI_ICTransCancel" timeout="5000" comment="">
      <Forward event="OnTimeout" targetID="ID_ReturnCard" />
      <Forward event="OnFail" targetID="ID_ReturnCard" />
    </Prompt>
    <!--获取芯片的数据-->
    <ICGetTrack ID="ID_ICGetTrack" comment="Get IC tracks">
      <Forward event="OnConfirm" targetID="ID_PrintCardNum" />
      <Forward event="OnCancel" targetID="ID_ReturnCard" />
    </ICGetTrack>
    <SetData ID="ID_SetDefaultCHN" saveBuffer="{core_PAN,1}" value = "621700000000000001">
      <Forward event="OnConfirm" targetID="ID_PrintCardNum"/>
      <!-- <Forward event="OnConfirm" targetID="ID_SendFlowSetPIN"/> -->
    </SetData>

	  <PrintCard ID="ID_PrintCardNum" UI="UI_dispense_card" digitalVoiceKey="|action_021" PrintSource="core_PAN" FontSize="50" FontName="Arial" FontType="0" X="80" Y="440" timeout="120000">
      <States>
        <State name="PrintCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_PrintCardHolderName"/>
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError"/>
      <DefaultForward targetID="ID_ReturnCardForHardwareError"/>
    </PrintCard>

	  <PrintCard ID="ID_PrintCardHolderName" UI="UI_dispense_card" digitalVoiceKey="|action_021" PrintSource="CardHolderName" FontSize="50" FontName="Arial" FontType="0" X="80" Y="340" timeout="120000">
      <States>
        <State name="PrintCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_SendFlowSetPIN"/>
      <!-- <Forward event="OnConfirm" targetID="ID_PrintCardBackground"/> -->
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError"/>
      <DefaultForward targetID="ID_ReturnCardForHardwareError"/>
    </PrintCard>

    <!-- 印卡打印背景图片 -->
    <!-- <PrintCardBackground ID="ID_PrintCardBackground" UI="UI_dispense_card" digitalVoiceKey="|action_021" BDir="C:/bdir.bmp" FDir="C:/fdir.bmp" timeout="120000">
      <States>
        <State name="PrintCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_SendFlowSetPIN"/>
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError"/>
      <DefaultForward targetID="ID_ReturnCardForHardwareError"/>
    </PrintCardBackground> -->
	
	<VTMAActBusinessFlow ID="ID_SendFlowSetPIN" UI="" CurrentStep="userSetPassword" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_InputNewPin" />
    </VTMAActBusinessFlow>
		
	<VTMInputPinEx ID="ID_InputNewPin" comment="Enter your new PIN" digitalVoiceKey="action_069|action_008||action_021" autoEnd="1" minLen="6" maxLen="6" timeout="120000">
      <States>
        <State name="InputNewPin" UI="UI_Input_PIN" />
        <State name="InputNewPinAgain" UI="UI_Input_PINAgain" />
        <State name="InputNewPinUnmatch" UI="UI_Input_PINIncorrect" />
      </States>
      <Forward event="OnConfirm" targetID="ID_DispenseCardSuccess" />
      <Forward event="OnCancel" targetID="ID_ReturnCardForHardwareError" />
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError" />
      <Forward event="OnTimeout" targetID="ID_ReturnCardForHardwareError" />
      <DefaultForward targetID="ID_ReturnCardForHardwareError" />
    </VTMInputPinEx>
	
	 <CRDDispenseCardSuccess ID="ID_DispenseCardSuccess" UI="UI_dispense_card" digitalVoiceKey="|action_022|||action_021" homeEnable="0" IsNeverTimedOut="false" timeout="30000">
      <States>
        <State name="EjectWait" UI="UI_dispense_card"/>
        <State name="TakeCard" UI="UI_take_card"/>
        <State name="EjectCardError" UI="UI_timeout"/>
        <State name="TransTimeOut" UI="UI_timeout"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SendFlowPrintReceipt"/>
      <Forward event="OnHardwareError" targetID="ID_ReturnCardForHardwareError"/>
      <Forward event="OnTimeout" targetID="ID_ReturnCardForNotTake"/>
    </CRDDispenseCardSuccess>
	
	<VTMAActBusinessFlow ID="ID_SendFlowPrintReceipt" UI="" CurrentStep="printReceipt" FlowStatus="0" timeout="50000">
      <DefaultForward targetID="ID_PrintReceiptForCloseTrans" />
    </VTMAActBusinessFlow>
	
	<!--不拿卡吞卡-->
	<CRDReturnCard ID="ID_ReturnCardForNotTake" UI="UI_waiting" digitalVoiceKey="|" captureCardReason="1" homeVisible="0">
      <States>
        <State name="ReturnCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_TakeCardTimeout"/>
      <Forward event="OnHardwareError" targetID="ID_TakeCardTimeout"/>
      <Forward event="OnTakeCardSuccess" targetID="ID_ComparePrintingReceiptFlag"/>
    </CRDReturnCard>

	<!--发卡器故障吞卡-->
	<CRDReturnCard ID="ID_ReturnCardForHardwareError" UI="UI_waiting" digitalVoiceKey="|" captureCardReason="2" homeVisible="0">
      <States>
        <State name="ReturnCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_TakeCardTimeout"/>
      <Forward event="OnHardwareError" targetID="ID_TakeCardTimeout"/>
    </CRDReturnCard>

    <!-- 主机要求吞卡 -->
    <CRDReturnCard ID="ID_ReturnCardHostDemand" UI="UI_waiting" digitalVoiceKey="|" captureCardReason="3" homeVisible="0">
      <States>
        <State name="ReturnCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SetCaptureCardFlag"/>
      <Forward event="OnHardwareError" targetID="ID_SetCaptureCardFlag"/>
    </CRDReturnCard>

    <!-- 吞卡后打印凭条 -->
    <CRDReturnCard ID="ID_ReturnCardReset" UI="UI_waiting" digitalVoiceKey="|" homeVisible="0">
      <States>
        <State name="ReturnCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SetCaptureCardFlag"/>
      <Forward event="OnHardwareError" targetID="ID_SetCaptureCardFlag"/>
    </CRDReturnCard>

    <!-- 吞卡后结束交易 -->
    <CRDReturnCard ID="ID_ReturnCard" UI="UI_waiting" digitalVoiceKey="|" homeVisible="0">
      <States>
        <State name="ReturnCardError" UI="UI_hardware_error"/>
      </States>
      <Forward event="OnContinue" targetID="ID_SetCaptureCardFlag"/>
      <Forward event="OnHardwareError" targetID="ID_SetCaptureCardFlag"/>
    </CRDReturnCard>
	
	
	<SetData ID="ID_SetCaptureCardFlag" saveBufferBool="{core_HostAskCaptureCardTemp}" value="True">
      <Forward event="OnConfirm" targetID="ID_PrintReceiptForCloseTrans"/>
    </SetData>

	<!--审核不通过-->
	<WaitSleep ID="ID_AuditingFailCard" UI="UI_agent_refuse" digitalVoiceKey="action_023" timeout="3000">
      <Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow" />
    </WaitSleep>

    <WaitSleep ID="ID_ConnectAgentFail" UI="UI_network_error" timeout="5000">
      <Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow" />
    </WaitSleep>

    <WaitSleep ID="ID_TransTimeOut" UI="UI_timeout" timeout="5000">
      <Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow" />
    </WaitSleep>
	
	<WaitSleep ID="ID_HostRefuse" UI="UI_host_refuse" digitalVoiceKey="action_024" timeout="5000">
      <Forward event="OnContinue" targetID="ID_ReturnCardHostDemand" />
    </WaitSleep>
  
	<WaitSleep ID="ID_TakeCardTimeout" UI="UI_card_captured" digitalVoiceKey="action_025" timeout="5000">
      <Forward event="OnContinue" targetID="ID_SetCaptureCardFlag" />
    </WaitSleep>
	<!-- 打印凭条后结束交易 -->
    <PrintReceipt ID="ID_PrintReceiptForCloseTrans" UI="UI_PrintingReceipt" digitalVoiceKey="||action_026" formName="ReceiptFormCardEN" showTime="3000">
      <States>
        <State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess4IssueCard"/>
        <State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
      </States>
      <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow"/>
    </PrintReceipt>
    <InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" name="VTMACloseTrans" comment="Invoke close trans workflow">
      <Forward event="OnConfirm" targetID="9999"/>
    </InvokeWorkflow>

    <InvokeWorkflow ID="ID_InvokeRequestAgent_WF" name="RequestAgent_WF" comment="Invoke help workflow" fallBackAfterEnd="1">
      <Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow" />
    </InvokeWorkflow>
    <End ID="9999" comment="End">
    </End>
  </Activities>
  <DefaultForward>
    <Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
    <Forward event="OnCusBusy" targetID="ID_CusBusyFail"/>
    <Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
    <Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
    <Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
    <Forward event="OnCancel" targetID="ID_OtherTrans"/>
    <Forward event="OnKeyError" targetID="ID_EventError"/>
    <Forward event="OnRollbackForError" targetID="ID_InvokeCloseTransWorkflow"/>
    <Forward event="OnHelp" targetID="ID_InvokeRequestAgent_WF"/>
	<Forward event="OnNetworkFail" targetID="ID_InvokeCloseTransWorkflow"/>	
  </DefaultForward>
</Workflow>