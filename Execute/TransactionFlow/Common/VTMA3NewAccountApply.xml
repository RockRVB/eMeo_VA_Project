<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="VTMA3NewAccount">
  <Head type="GRGWorkflow" author="" timeStamp="" comment="The workflow design is for Card printing Demo"/>
  <DataPool>
  </DataPool>
  <Activities>
    <Start ID="0" comment="Start" callVisible="0" endflag="1">
      <Forward event="OnConfirm" targetID="ID_SetUserModeType"/>
    </Start>
	<SetData ID="ID_SetUserModeType" saveBuffer="{VTMA.send.CallRemoteTeller.userModeType,0}" value="1">
		<Forward event="OnConfirm" targetID="ID_SetTransactionID"/>
	</SetData>
	<!-- Set transactionID-->
    <SetData ID="ID_SetTransactionID" saveBuffer="{VTMA.send.CallRemoteTeller.args.businessInfo.transaction, 0}" value="2">
      <Forward event="OnConfirm" targetID="ID_SetTransTypeNewCard" />
    </SetData>
	<SetData ID="ID_SetTransTypeNewCard" saveBuffer="{VTM_TransTypeName,0}" value="VTM_Standard_OpenAccount">
      <Forward event="OnConfirm" targetID="ID_CompareVideoStatus"/>
    </SetData>
	<!--Check Agin Video Connection-->
	<!-- 判断视频状态 -->
    <!-- STATUS_END = 0,        未初始化前的状态，登陆前状态  -->
    <!-- STATUS_INITIAL_REQ,    初始化请求状态, 登陆中状态  -->
    <!-- STATUS_IDLE,           初始化成功后还未呼叫时的空闲状态  -->
    <!-- STATUS_CALL_REQ,       呼叫发起请求状态  -->
    <!-- STATUS_IN_TALKING,     通话中状态  -->
    <!-- STATUS_RELEASE_REQ,    呼叫发起释放状态  -->
    <!-- STATUS_ENDING_REQ,     发起结束初始化状态  -->
    <!-- STATUS_ANSWER_REQ,     应答中，此时点击应答，等有TALKING事件上报后，将迁移到STATUS_IN_TALKING  -->
    <!-- STATUS_IN_CALLING,     正在 来电中， 也就是收到振铃事件；对于AVAYA，主叫会收到振铃事件但被叫反而不会收到振铃事件  -->
    <!-- STATUS_IN_REJECTING,   正在拒绝中  -->
    <!-- STATUS_NETWORK_ERROR,  网络故障  -->
    <CompareData ID="ID_CompareVideoStatus" comment="" compareBuffer="{VTM_VideoStatusWrapper}">
      <Forward event="OnEqualSTATUS_IN_TALKING" targetID="ID_ChangeBusiness" />
      <Forward event="OnEqualSTATUS_IDLE" targetID="ID_InvokeCallAgentWorkflow" />
      <DefaultForward targetID="ID_ConnectAgentFail" />
    </CompareData>

    <VTMARequestTransViaRestful ID="ID_ChangeBusiness" UI="UI_waiting" digitalVoiceKey="" transType="ChangeBusiness" transFormat="json" msgTimeout="2000">
      <Forward event="OnContinue" targetID="ID_SendFlowCardProtocol"/>
      <DefaultForward targetID="ID_SendFlowCardProtocol" />
	</VTMARequestTransViaRestful>
	
    <!-- Invoke the Authorization workflow-->
    <InvokeWorkflow ID="ID_InvokeCallAgentWorkflow" name="VTMA3CallAgent" comment="Invoke CallAgent workflow" index="0">
      <Forward event="OnConfirm" targetID="ID_CompareVideoStatusAgain"/>
    </InvokeWorkflow>	
	
	<!-- Judge whether the agent is connected or not -->
	  <CompareData ID="ID_CompareVideoStatusAgain" comment="" compareBuffer="{VTM_VideoStatusWrapper}"> 
      <Forward event="OnEqualSTATUS_IN_TALKING" targetID="ID_ChangeBusiness" />
      <DefaultForward targetID="ID_ConnectAgentFail" />
    </CompareData>
	
	<VTMAActBusinessFlow ID="ID_SendFlowCardProtocol" UI="" CurrentStep="readAgreement" FlowStatus="99" timeout="50000">
      <DefaultForward targetID="ID_CardProtol" />
    </VTMAActBusinessFlow>

    <!--view CardProtol-->
    <VTMSelectFunction ID="ID_CardProtol" UI="UI_card_protocol" digitalVoiceKey="action_011" timeout="120000" homeVisible="1" index="2">
      <Forward event="OnConfirm" targetID="ID_ScanByPassportGetDevStatusEx"/>
      <!-- <Forward event="OnConfirm" targetID="ID_IDCardGetDevStatusEx"/> -->
	    <Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
    </VTMSelectFunction>
    <GetDevStatusEx ID="ID_ScanByCAMGetDevStatusEx" UI="UI_waiting" digitalVoiceKey="|" comment="Get device status" devType="CAM" callVisible="0">
