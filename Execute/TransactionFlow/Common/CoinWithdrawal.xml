<?xml version="1.0" encoding="UTF-8"?>
<Workflow name="CoinWithdrawal">
	<Head type="GRGWorkflow" author="HXL" timeStamp="2012/04/12 19:15:12" comment="The workflow design is for withdrawal"/>
	<DataPool>
	</DataPool>
	<Activities>
		<Start ID="0" comment="Start">
			<Forward event="OnConfirm" targetID="ID_InputWithdrawalAmount"/>
		</Start>
		<InputCoinWithdrawalAmount ID="ID_InputWithdrawalAmount" UI="UI_InputWithdrawalAmount" comment="Input withdrawal amount" keyValueMap="[F1,100][F2,2000][F3,500][F5,800][F7,1000]" maxRetryTimes="0">
			<Forward event="OnConfirm" targetID="ID_RequestTrans"/>
			<Forward event="OnContinue" targetID="9999"/>
		</InputCoinWithdrawalAmount>
		<RequestTrans ID="ID_RequestTrans" UI="UI_RequestTrans" comment="Withdrawal request">
			<States>
				<State name="PackFail" UI="UI_GeneralError"/>
				<State name="ConnectFail" UI="UI_GeneralError"/>
				<State name="SendFail" UI="UI_GeneralError"/>
				<State name="ReceiveFail" UI="UI_GeneralError"/>
				<State name="ReceiveTimeout" UI="UI_GeneralError"/>
				<State name="NetworkFail" UI="UI_GeneralError"/>
				<State name="UnpackFail" UI="UI_GeneralError"/>
				<State name="HardwareError" UI="UI_GeneralError"/>
				<State name="TransNotAccepted" UI="UI_ICTransNotAccepted"/>
				<State name="TransDeclined" UI="UI_ICTransDeclined"/>
				<State name="TransTerminated" UI="UI_ICTransTerminated"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_DispenseCash"/>
			<Forward event="OnPackFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnConnectFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnSendFail" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnReceiveFail" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnReceiveTimeout" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnNetworkFail" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnUnpackFail" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnHostRefuse" targetID="ID_HostRefuse"/>
			<Forward event="OnReInputPin" targetID="ID_ReInputPin"/>
			<Forward event="OnFallback" targetID="ID_RequestTrans"/>
			<Forward event="OnTryAgain" targetID="ID_TryAgain"/>
			<Forward event="OnICAppLoadedFail" targetID="ID_InvokeCloseTransWorkflow"/>
		</RequestTrans>
		<InputPin ID="ID_ReInputPin" UI="UI_ReInputPin" comment="ReInput password">
			<Forward event="OnConfirm" targetID="ID_RequestTrans"/>
		</InputPin>
		<!--主机拒绝，显示拒绝码对应的提示信息，然后退卡-->
		<Prompt ID="ID_HostRefuse" UI="UI_HostRefuse" timeout="5000" comment="show host refuse">
			<Forward event="OnTimeout" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnFail" targetID="ID_GetDevStatusForCloseTrans"/>
		</Prompt>
		<DispenseCoin ID="ID_DispenseCash" UI="UI_PresentCash" comment="Dispense cash">
			<States>
				<State name="DispenseAmountError" UI="UI_DispenseAmountError"/>
				<State name="RejectingCash" UI="UI_RejectingCash"/>
				<State name="RejectCashForHardwareError" UI="UI_RejectCashForHardwareError"/>
				<State name="RejectCashFail" UI="UI_RejectCashFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_GetDevStatusForCloseTrans"/>
			<Forward event="OnHardwareError" targetID="ID_GetDevStatusForCloseTrans"/>
		</DispenseCoin>
		<PresentCash ID="ID_PresentCash" UI="UI_PresentCash" comment="Present cash">
			<States>
				<State name="TakeCash" UI="UI_TakeCash"/>
				<State name="RetractingCash" UI="UI_RetractingCash"/>
				<State name="RetractCashForTimeout" UI="UI_RetractCashForTimeout"/>
				<State name="RetractCashForHardwareError" UI="UI_RetractCashForHardwareError"/>
				<State name="RetractNoCash" UI="UI_RetractNoCash"/>
				<State name="RetractCashFail" UI="UI_RetractCashFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_GetDevStatus"/>
			<Forward event="OnHardwareError" targetID="ID_GetDevStatusForCloseTrans"/>
		</PresentCash>
		<GetDevStatus ID="ID_GetDevStatus" comment="Get device status" devType="RPTR">
			<Forward event="OnNormal" targetID="ID_SelectReceiptType"/>
			<Forward event="OnWarn" targetID="ID_SelectReceiptType"/>
			<Forward event="OnFail" targetID="9999"/>
		</GetDevStatus>
		<!-- 选择打印凭证类型 -->
		<SelectFunction ID="ID_SelectReceiptType" UI="UI_SelectReceiptType" commandMap="[F4,REC][F6,RECOCR]" keyButtons="F4|F6" comment="Select receipt type">
			<Forward event="OnF4" targetID="ID_PrintReceipt"/>
			<Forward event="OnF6" targetID="ID_PrintReceiptOCR"/>
			<Forward event="OnF7" targetID="ID_InvokeCloseTransWorkflow"/>
			<Forward event="OnF8" targetID="9999"/>
			<Forward event="OnConfirm" targetID="9999"/>
			<Forward event="OnContinue" targetID="9999"/>
		</SelectFunction>
		<!-- 开始打印凭条 -->
		<PrintReceipt ID="ID_PrintReceipt" UI="UI_PrintingReceipt" formName="" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_SelectReceiptType"/>
		</PrintReceipt>
		<!-- 开始打印冠字号凭条 -->
		<PrintOCRInfo ID="ID_PrintReceiptOCR" UI="UI_PrintingOCRReceipt" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_SelectReceiptType"/>
		</PrintOCRInfo>
		<!-- 是否打印凭条 
		<SelectFunction ID="ID_IsPrintReceipt" UI="UI_IsPrintReceipt">
			<Forward event="OnYes" targetID="ID_PrintReceipt"/>
			<Forward event="OnNo" targetID="9999"/>
		</SelectFunction>-->
		<!-- 开始打印凭条 
		<PrintReceipt ID="ID_PrintReceipt" UI="UI_PrintingReceipt" formName="" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="9999"/>
		</PrintReceipt>-->
		<GetDevStatus ID="ID_GetDevStatusForCloseTrans" comment="Get device status for closing transaction" devType="RPTR">
			<Forward event="OnNormal" targetID="ID_PrintReceiptForCloseTrans"/>
			<Forward event="OnWarn" targetID="ID_PrintReceiptForCloseTrans"/>
			<Forward event="OnFail" targetID="ID_InvokeCloseTransWorkflow"/>
		</GetDevStatus>
		<!-- 判断是否开启CDM OCR -->
		<CompareData ID="ID_CompareIsSuportCDMOCR" compareBuffer="{core_EnableOCRCDM}" comment="是否开启CDM的OCR">
			<Forward event="OnEqualTrue" targetID="ID_IsRetractForTimeout"/>
            <Forward event="OnEqualFalse" targetID="ID_PrintReceiptForCloseTrans"/>
            <DefaultForward targetID="ID_PrintReceiptForCloseTrans"/>
		</CompareData>
		<!--判断是否超时回收-->
		<CompareData ID="ID_IsRetractForTimeout" compareBuffer="{core_IsRetractSuccessFlag}" comment="是否回收成功">
			<!--<Forward event="OnEqualTrue" targetID="ID_SelectReceiptTypeCloseTrans"/> 
			超时回收 直接打印普通凭条，不再到选择凭条界面 如还要到选择凭条界面，那么用注释的这一句 by lsjie5-->
            <Forward event="OnEqualTrue" targetID="ID_PrintReceiptForCloseTrans"/>
			<Forward event="OnEqualFalse" targetID="ID_PrintReceiptForCloseTrans"/>
			<Forward event="OnEqualNull" targetID="ID_PrintReceiptForCloseTrans"/>
		</CompareData>
		<!--<IsRetractForTimeout ID="ID_IsRetractForTimeout">
			<Forward event="OnYes" targetID="ID_SelectReceiptTypeCloseTrans"/>
			<Forward event="OnNo" targetID="ID_PrintReceiptForCloseTrans"/>
			<Forward event="OnWarn" targetID="ID_PrintReceiptForCloseTrans"/>
		</IsRetractForTimeout>-->
		<!--超时回收时选择打印凭证-->
		<SelectFunction ID="ID_SelectReceiptTypeCloseTrans" UI="UI_SelectReceiptTypeCloseTrans" commandMap="[F4,REC][F6,RECOCR]" keyButtons="F4|F6" comment="Select receipt type" defaultEvent="OnContinue">
			<Forward event="OnF4" targetID="ID_PrintReceiptCloseTrans"/>
			<Forward event="OnF6" targetID="ID_PrintReceiptOCRCloseTrans"/>
			<Forward event="OnContinue" targetID="ID_InvokeCloseTransWorkflow"/>
		</SelectFunction>
		<!-- 设备故障或非主动存钞时开始打印冠字号凭条 -->
		<PrintOCRInfo ID="ID_PrintReceiptOCRCloseTrans" UI="UI_PrintingOCRReceipt" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_SelectReceiptTypeCloseTrans"/>
		</PrintOCRInfo>
		<!-- 设备故障或非主动存钞时开始打印凭条 -->
		<PrintReceipt ID="ID_PrintReceiptCloseTrans" UI="UI_PrintingReceipt" formName="" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_SelectReceiptTypeCloseTrans"/>
		</PrintReceipt>
		<PrintReceipt ID="ID_PrintReceiptForCloseTrans" UI="UI_PrintingReceipt" formName="" showTime="2000">
			<States>
				<State name="PrintReceiptSuccess" UI="UI_PrintReceiptSuccess"/>
				<State name="PrintReceiptFail" UI="UI_PrintReceiptFail"/>
			</States>
			<Forward event="OnConfirm" targetID="ID_InvokeCloseTransWorkflow"/>
		</PrintReceipt>
		<InvokeWorkflow ID="ID_InvokeCloseTransWorkflow" name="CloseTrans" comment="Invoke close trans workflow">
			<Forward event="OnConfirm" targetID="9999"/>
		</InvokeWorkflow>
		<End ID="9999" comment="End">
		</End>
		<InvokeWorkflow ID="ID_TryAgain" name="Main" comment="IC returns TryAgain" actionID="ID_ICMoreAppSelectForMainMenu" syn="0">
		</InvokeWorkflow>
	</Activities>
	<DefaultForward>
		<Forward event="OnCancel" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnTimeout" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnKeyError" targetID="ID_InvokeCloseTransWorkflow"/>
		<Forward event="OnHardwareError" targetID="ID_InvokeCloseTransWorkflow"/>
	</DefaultForward>
</Workflow>
