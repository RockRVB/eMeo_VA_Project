		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="L" value="NDCCardWriteState" description="Card Writet State" />
    <Item key="M" value="NDCPinEntry" description="Enhance Pin Entry State" />
    <!--It must has this parameter, if it can not found in 
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
    <!--必须要有，否则
		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="N" value="NDCCameraControl" description="Camera Control State" />
    <Item key="R" value="NDCEnhancedAmountEntry" description="Enhance Amount Entry State" />
    <Item key="S" value="NDCLanguageCodeSwitchState" description="Language Code Switch State" />
    <!--It must has this parameter, if it can not found in
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
    <!--必须要有，否则
		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="T" value="NDCCardReadState" description="Card Read - Pin Entry Initiation State" />
    <Item key="U" value="NDCDeviceFitnessFlowSelectState" description="" />
    <Item key="V" value="NDCLanguageSelectFromCard" description="Language Select From Card State" />
    <Item key="W" value="NDCFDKSwitchState" description="Card Read - Pin Entry Initiation State" />
    <Item key="X" value="NDCFDKInformationEntryState" description="Language Select From Card State" />
    <Item key="Y" value="NDCEightFDKSelect" description="Eight FDK Selection Function State" />
    <Item key="b" value="NDCCustomerSelectablePIN" description="Customer-Selectable PIN State" />
    <Item key="g" value="NDCFitSwitchExitState_g" description="NDCFitSwitchExitState_g" />
    <!--It must has this parameter, if it can not found in
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
    <!--必须要有，否则
		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="d-g" value="ExitStates" description="Exit State" />
    <Item key="m" value="NDCPinLanguageSelectState" description="Pin and Language Select State" />
    <Item key="z013" value="NDCDataCopyAndCompareState" description="NDCDataCopyAndCompareState" />
    <!--It must has this parameter, if it can not found in
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
    <!--必须要有，否则
		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="w" value="NDCChequeAcceptState" description="Cheque Acceptt State" />
    <Item key="z001" value="NDCBunchChequeAcceptState_z001" description="z001 – Bunch Cheque Accept State" />
    <Item key="z002" value="NDCBunchChequeHandlingState_z002" description="z002 – Bunch Cheque Handling State" />
    <Item key="z003" value="NDCChequeDetailDisplayState_z003" description="z003 – Cheque Detail Display State" />
    <Item key="z004" value="NDCDisplayChequeSummary_z004" description="z004 – Display Cheque Summary State" />
    <Item key="z005" value="NDCFingerSelectionState" description="NDCFingerSelectionState" />
    <Item key="z006" value="NDCFingerprintCaptureState" description="NDCFingerprintCaptureState" />
    <Item key="z025" value="NDCFingerprintRemoteAuthenticationState" description="NDCFingerprintRemoteAuthenticationState" />
    <!--It must has this parameter, if it can not found in
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
    <!--必须要有，否则
		在Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		找不到，返回False-->
    <Item key="Z" value="NDCCloseState" description="Z" />
    <Item key="&amp;" value="NDCBarCodeState" description="Barcode" />
    <Item key="TimeOut" value="TimeOut" description="Time-Out State" />
    <!--for ndc emv by ccyao-->
    <Item key="-" value="NDCEmvAutoLangSel" description="Automatic Language Selection" />
    <Item key="." value="NDCEmvBeginIccAppSelectInit" description="Begin ICC application Selection and Initialization" />
    <Item key="+" value="NDCEmvBeginIccInit" description="Begin ICC Initialization" />
    <Item key="/" value="NDCEmvCompleteIccAppSelectInit" description="Complete ICC application Selection and Initialization" />
    <Item key="," value="NDCEmvCompleteIccInit" description="Complete ICC Initialization" />
    <Item key="d" value="NDCEmvExitState_d" description="Chip Data Read State " />
    <Item key="e" value="NDCEmvExitState_e" description="EMV Core transaction state " />
    <Item key="f" value="NDCEmvExitState_f" description="EMV Non-core transaction state" />
    <Item key=";" value="NDCEmvReIccInit" description="ICC Re-initializes" />
    <Item key="?" value="NDCEmvSetIccTransactionData" description="Set ICC Transaction Data" />
    <Item key="k" value="NDCEmvSmartFITCheck" description="Smart FIT Check State" />
    <Item key="r" value="WincorNDCCashAcceptorState" description="Wincor NDC Deposit" />
    <Item key="c" value="NDCCashDepositState" description="NDCCashDepositState" />
    <Item key="z007" value="NDCEMVSmartDIPTakeCard" description="NDCEMVSmartDIPTakeCard" />
    <Item key="z012" value="NDCEMVApplicationSwitch" description="NDCEMVApplicationSwitch" />
    <Item key="z008" value="NDCInsertCardState" description="NDCInsertCardState" />
    <Item key="z026" value="NDCCardEjectState" description="NDCCardEjectState" />
    <Item key="z024" value="NDCPrepareDispenseState" description="NDC Prepare Dispense State" />
    <Item key="z020" value="NDCFITSearchState" description="NDC FIT Search State" />
    <Item key="z021" value="NDCCRMFlowpointState" description="NDC CRM Flowpoint State" />
    <Item key="z017" value="NDCNoteMixSelectionState" description="NDC Note Mix Selection State" />
    <!--for ndc emv by ccyao-->
  </StateType>
  <StateFormat>
    <!-- 
 * The state format definition of card read state type
-   -->
    <CardRead>
      <Item key="0" value="Type" size="1" description="StateType" />
      <Item key="1" value="ScrNum" size="3" description="Screen Number (Range 000 - 999)" />
      <Item key="2" value="GoodNext" size="3" description="[1]Good read. [2]FIT matched" />
      <Item key="3" value="ErrScrNum" size="3" description="Read card error" />
      <Item key="4" value="ReadCondition1" size="3" description="Read condition 1" />
      <Item key="5" value="ReadCondition2" size="3" description="Read condition 2" />
      <Item key="6" value="ReadCondition3" size="3" description="Read condition 3" />
      <Item key="7" value="CardReturnFlag" size="3" description="[0] - Eject the card immediately [2]001-Retirm tje card as specified." />
      <Item key="8" value="MisMatchNext" size="3" description="Fit doesn't match with card data. [000] - Fits not used." />
    </CardRead>
    <!-- 
        * The state format definition of PIN Entry state type
-    -->
    <PinEntry>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen number" />
      <Item key="2" value="TimeOutNext" size="3" description="Time-Out next state" />
      <Item key="3" value="CancelNext" size="3" description="Cance nextl state" />
      <Item key="4" value="LocalPinGoodNext" size="3" description="Local Pin good check next state" />
      <Item key="5" value="LocalPinBadNext" size="3" description="Local Pin bad check next state" />
      <Item key="6" value="LocalPinErrScrNum" size="3" description="Local Pin error check screen number" />
      <Item key="7" value="RemotePinChkNext" size="3" description="Local Pin not performed(Remote)" />
      <Item key="8" value="LocalMaxRetry" size="3" description="Maximum number of incorrect Pin entries for local PIN check" />
    </PinEntry>
    <!-- 
       * The state format definition of envelope dispenser state type
-    -->
    <EnvelopeDispenser>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="NextState" size="3" description="Next state" />
      <Item key="2" value="Reservered" size="3" description="Reservered" />
      <Item key="3" value="Reservered" size="3" description="Reservered" />
      <Item key="4" value="Reservered" size="3" description="Reservered" />
      <Item key="5" value="Reservered" size="3" description="Reservered" />
      <Item key="6" value="Reservered" size="3" description="Reservered" />
      <Item key="7" value="Reservered" size="3" description="Reservered" />
      <Item key="8" value="Reservered" size="3" description="Reservered" />
    </EnvelopeDispenser>
    <!-- 
       * The state format definition of Pre-Set Operation Code Buffer state type
-    -->
    <PreSetOpCodeBuf>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="NextState" size="3" description="Next state" />
      <Item key="2" value="ClearMask" size="3" description="Set the specifies bytes of buffer to 'space' according to each bit." />
      <Item key="3" value="PreSetA" size="3" description="Set the specifies bytes of buffer to 'A' according to each bit." />
      <Item key="4" value="PreSetB" size="3" description="Set the specifies bytes of buffer to 'B' according to each bit." />
      <Item key="5" value="PreSetC" size="3" description="Set the specifies bytes of buffer to 'C' according to each bit." />
      <Item key="6" value="PreSetD" size="3" description="Set the specifies bytes of buffer to 'D' according to each bit." />
      <Item key="7" value="Reservered" size="3" description="Reservered" />
      <Item key="8" value="ExState" exState="PreSetOpCodeBufEx" size="3" description="Extension state number." />
    </PreSetOpCodeBuf>
    <!-- 
       * The state format definition of Extension Pre-Set Operation Code Buffer state type
-    -->
    <PreSetOpCodeBufEx>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="PreSetF" size="3" description="Set the specifies bytes of buffer to 'F' according to each bit" />
      <Item key="2" value="PreSetG" size="3" description="Set the specifies bytes of buffer to 'G' according to each bit" />
      <Item key="3" value="PreSetH" size="3" description="Set the specifies bytes of buffer to 'H' according to each bit." />
      <Item key="4" value="PreSetI" size="3" description="Set the specifies bytes of buffer to 'I' according to each bit" />
      <Item key="5" value="Reservered" size="3" description="Reservered." />
      <Item key="6" value="Reservered" size="3" description="Reservered." />
      <Item key="7" value="Reservered" size="3" description="Reservered" />
      <Item key="8" value="Reservered" size="3" description="Reservered" />
    </PreSetOpCodeBufEx>
    <!-- 
       * The state format definition of Four FDK Seletion Function state type
-    -->
    <FourFdkSelFunc>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen number" />
      <Item key="2" value="TimeOutNext" size="3" description="Time-Out next state number" />
      <Item key="3" value="CancelNext" size="3" description="Cancel next state number" />
      <Item key="4" value="FDKAI" size="3" description="Press FDK A or I " />
      <Item key="5" value="FDKBH" size="3" description="Press FDK B or H" />
      <Item key="6" value="FDKCG" size="3" description="Press FDK C or G." />
      <Item key="7" value="FDKDF" size="3" description="Press FDK D or F" />
      <Item key="8" value="BufferLocation" size="3" description="Define the operation code buffer byte in which keycode for the selection FDK is stored." />
    </FourFdkSelFunc>
    <!-- 
       * The state format definition of Amount Entry State type
-    -->
    <AmountEntry>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen number" />
      <Item key="2" value="TimeOutNext" size="3" description="Time-Out next state number" />
      <Item key="3" value="CancelNext" size="3" description="Cancel next state number" />
      <Item key="4" value="FDKAI" size="3" description="Press FDK A or I " />
      <Item key="5" value="FDKBH" size="3" description="Press FDK B or H" />
      <Item key="6" value="FDKCG" size="3" description="Press FDK C or G." />
      <Item key="7" value="FDKDF" size="3" description="Press FDK D or F" />
      <Item key="8" value="AmtDisplayScr" size="3" description="Amount Display Screen" />
    </AmountEntry>
    <!-- 
       * The state format definition of Amount Check State type
-    -->
    <AmountCheck>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="TrueNext" size="3" description="Amount check condition true to go to next state" />
      <Item key="2" value="FalseNext" size="3" description="Amount check condition false to go to next state" />
      <Item key="3" value="BufToBeChecked" size="3" description="Specify which buffer to be checked." />
      <Item key="4" value="IntegerMultiValue" size="3" description="Integer multiple value used in checking specified buffer(002)." />
      <Item key="5" value="NumOfDecimalPlaces" size="3" description="Number of decimal places used in specified buffer(not 000)." />
      <Item key="6" value="CurrencyType" size="3" description="Currency type of amount in specified buffer.(003)" />
      <Item key="7" value="AmtChkCondtion" size="3" description="Amount check condition required." />
      <Item key="8" value="Reservered" size="3" description="Reservered" />
    </AmountCheck>
    <!-- 
       * The state format definition of Information Entry State type
-    -->
    <InformationEntry>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen number" />
      <Item key="2" value="TimeOutNext" size="3" description="Time-Out next state number" />
      <Item key="3" value="CancelNext" size="3" description="Cancel next state number" />
      <Item key="4" value="FDKAI" size="3" description="Press FDK A or I " />
      <Item key="5" value="FDKBH" size="3" description="Press FDK B or H" />
      <Item key="6" value="FDKCG" size="3" description="Press FDK C or G." />
      <Item key="7" value="FDKDF" size="3" description="Press FDK D or F" />
      <Item key="8" value="BufDisplayPara" size="3" description="Buffer and display parameters(Range 000-003)" />
    </InformationEntry>
    <!-- 
       * The state format definition of Transaction Request State type
-    -->
    <TransactionRequest>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen number" />
      <Item key="2" value="TimeOutNext" size="3" description="Central ResponseTime-Out next state number" />
      <Item key="3" value="Track2Condition" size="3" description="Send Track 2 Data Condition" />
      <Item key="4" value="Track1And3Condition" size="3" description="Send Track 1 and/or Track 3 Data Condition" />
      <Item key="5" value="SndOpCode" size="3" description="Send Operation Code Data" />
      <Item key="6" value="SndAmtData" size="3" description="Send Amount Data" />
      <Item key="7" value="PINBufFormat" size="3" description="Send PIN buffer(buffer A) data/select extended format" />
      <Item key="8" value="BufBCOrExStateNum" size="3" description="Send General Purpose buffer B and/or C or extension state number(Range 000-003, or [valid state number]" />
    </TransactionRequest>
    <!-- 
       * The state format definition of Transaction Request State type
-    -->
    <TransactionRequestEx>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="BufBC" size="3" description="Send Buffers B and/or C" />
      <Item key="2" value="SndOpFieldAH" size="3" description="Send Optional Data Fields('A' - 'H')" />
      <Item key="3" value="SndOpFieldIL" size="3" description="Send Optional Data Fields('I' - 'L')" />
      <Item key="4" value="SndOpFieldQa" size="3" description="Send Optional Data Fields('Q - 'a')" />
      <Item key="5" value="SndOpOthers" size="3" description="Send Operation Code Data Fields (Range 000-001)" />
      <Item key="6" value="Reserved" size="3" description="Reseved Data" />
      <Item key="7" value="EMVCamProcessFlag" size="3" description="Indicates if EMV CAM procssing is to be performed." />
      <Item key="8" value="Reserved" size="3" description="Reserved" />
    </TransactionRequestEx>
    <!-- 
       * The state format definition of Close State type
-    -->
    <Close>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="RcptDeliverScrNum" size="3" description="Display screen only if a receipt is delivered" />
      <Item key="2" value="Next" size="3" description="Next State Number" />
      <Item key="3" value="NoRcptDeliverScrNum" size="3" description="Display screen only if no receipt is delivered and no card captured in close state" />
      <Item key="4" value="CardRetainedScrNum" size="3" description="Display screen only if card captured in close state" />
      <Item key="5" value="StatementDeliverScrNum" size="3" description="Display screen only if statement is cut and delivered in close state" />
      <Item key="6" value="Reserved" size="3" description="Reseved Data" />
      <Item key="7" value="BNANoteReturnScrNum" size="3" description="Display screen to inform the cardholder that the BNA notes are being returned." />
      <Item key="8" value="ExStateNum" size="3" description="State number of the optional extension state." />
    </Close>
    <!-- 
       * The state format definition of Extension Close State type
-    -->
    <CloseEx>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="CPMTakeDocScrNum" size="3" description="Display screen only if CPM is present in error recovery action." />
      <Item key="2" value="CPMDocRetFlag" size="3" description="The flag controls the error recovery actions which may take place in the state if the CPM is present" />
      <Item key="3" value="Reserved" size="3" description="Reserved" />
      <Item key="4" value="Reserved" size="3" description="Reserved" />
      <Item key="5" value="Reserved" size="3" description="Reserved" />
      <Item key="6" value="Reserved" size="3" description="Reserved" />
      <Item key="7" value="CPMDocRetLeaveFlag" size="3" description="Leave Flag: The flag controls the error recovery actions which may take place in the state if the CPM is present" />
      <Item key="8" value="Reserved" size="3" description="Reserved" />
    </CloseEx>
    <!-- 
       * The state format definition of FIT Switch State type
-    -->
    <FitSwitch>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="0" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="2" value="1" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="3" value="2" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="4" value="3" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="5" value="4" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="6" value="5" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="7" value="6" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="8" value="7" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
    </FitSwitch>
    <!-- 
       * The state format definition of Expanded FIT Switch State type
-    -->
    <ExFitSwitch>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="0" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="2" value="1" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="3" value="2" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="4" value="3" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="5" value="4" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="6" value="5" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="7" value="6" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="8" value="ExState" size="3" description="Extension State Number." />
    </ExFitSwitch>
    <!-- 
       * The state format definition of Extension Expanded FIT Switch State type
-    -->
    <ExFitSwitchEx>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="7" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="2" value="8" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="3" value="9" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="4" value="10" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="5" value="11" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="6" value="12" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="7" value="13" size="3" description="Next state. And index will be found in table entry 5  in FIT table." />
      <Item key="8" value="14" size="3" description="Extension State Number." />
    </ExFitSwitchEx>
    <!-- 
       * The state format definition of Card Write State type
-    -->
    <CardWrite>
      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen displayed during a Card Write operation.." />
      <Item key="2" value="GoodWriteNext" size="3" description="Good write and go to next state." />
      <Item key="3" value="BadWriteNext" size="3" description="Bad write and go to next state." />
      <Item key="4" value="NoWriteNext" size="3" description="No write and go to next state." />
      <Item key="5" value="Reserved" size="3" description="Reserved" />
      <Item key="6" value="Reserved" size="3" description="Reserved." />
