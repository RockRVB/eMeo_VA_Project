<?xml version="1.0" encoding="utf-8"?>
<Root>
  <!-- 
 * The definition of State Type
 * [1] Normal state with size = 1 from state type(A,B,C,D,etc.)
*  [2] Special State defined for Exit states and Time-Out state with variable size   
-->
  <Mode>
    <Item key="InService" value="XDCInService" />
    <Item key="OffLine" value="XDCOffLine" />
    <Item key="OutOfService" value="XDCOutOfService" />
    <Item key="Maintenance" value="XDCMaintenance" />
    <Item key="Suspend" value="XDCSuspend" />
    <Item key="PowerUp" value="XDCPowerUp" />
  </Mode>
  <StateType>
    <Item key="A" value="XDCInService" description="Card Read State" />
    <Item key="B" value="NDCPinEntry" description="PIN Entry State" />
    <Item key="CHK01" value="NDCCHKMediaInStart" description="NDCCHKMediaInStart" />
    <Item key="CHK02" value="NDCCHKWaitForInsert" description="NDCCHKWaitForInsert" />
    <Item key="CHK03" value="NDCCHKMediaIn" description="NDCCHKMediaIn" />
    <Item key="CHK04" value="NDCCHKMediaInShowResult" description="NDCCHKMediaInShowResult" />
    <Item key="CHK05" value="NDCCHKCancelMediaIn" description="NDCCHKCancelMediaIn" />
    <Item key="CHK06" value="NDCCHKMediaInRetract" description="NDCCHKMediaInRetract" />
    <Item key="CHK07" value="NDCCHKMediaInRollback" description="NDCCHKMediaInRollback" />
    <Item key="CHK08" value="NDCCHKWaitForMediaTaken" description="NDCCHKWaitForMediaTaken" />
    <Item key="C" value="NDCEnvelopeDispenserState" description="Envelope Dispenser State" />
    <Item key="D" value="NDCSetOperationCode" description="Pre-Set Operation Code Buffer State" />
    <Item key="E" value="NDCFourFdkSelect" description="Four FDK selection Function State" />
    <Item key="F" value="NDCAmountEntry" description="Amount Entry State" />
    <Item key="G" value="NDCAmountCheck" description="Amount Check State" />
    <Item key="H" value="NDCInformationEntry" description="Information Entry State" />
    <Item key="I" value="NDCTransactionRequest" description="Transaction Request State" />
    <Item key="J" value="NDCCloseState" description="Closet State" />
    <Item key="K" value="NDCFitSwitchState" description="FIT Switcht State" />
    <Item key="_" value="NDCFitSwitchState" description="Expanded FIT Switch State" />
    <!--It must has this parameter, if it can not found in
		Log.XdcTrace.LogError("Cannot find m_sData=" + m_sData + " in m_dStateType");
		return False-->
