      <Item key="2" value="TimeOutNext" size="3" description="Time out and go to next state." />
      <Item key="3" value="CancelNext" size="3" description="Cancel and go to next state." />
      <Item key="4" value="LocalPinGoodNext" size="3" description="Local PIN check good pin and go to next state." />
      <Item key="5" value="LocalPinMaxBadNext" size="3" description="Local PIN check maximum bad pin and go to next state" />
      <Item key="6" value="LocalPinErrScrNumt" size="3" description="Local PIN check error screen number." />
      <Item key="7" value="RemotePinNext" size="3" description="Remote PIN check and go to next state." />
      <Item key="8" value="LocalPinMaxPinRetry" size="3" description="Local PIN check maximum PIN check retries." />
