      <Item key="0" value="Type" size="1" description="State type" />
      <Item key="1" value="ScrNum" size="3" description="Screen Number to be displayed for timeout state.." />
      <Item key="2" value="[FDKAINext]" size="3" description="FDK A or I pressed and return to previous state.." />
      <Item key="3" value="FDKBHOrTimeout" size="3" description="FDK B or H pressed. Timeout Next state." />
      <Item key="4" value="CacelNext" size="3" description="Cancel key pressed. Cancel Next state." />
      <Item key="5" value="Reserved" size="3" description="Reserved" />
      <Item key="6" value="Reserved" size="3" description="Reserved." />
      <Item key="6" value="Reserved" size="3" description="Reserved" />
      <Item key="7" value="Reserved" size="3" description="Reserved" />
      <Item key="8" value="Reserved" size="3" description="Reserved" />
    </Timeout>
  </StateFormat>
</Root>