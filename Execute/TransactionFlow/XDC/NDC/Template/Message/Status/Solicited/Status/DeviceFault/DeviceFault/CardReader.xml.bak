<?xml version="1.0" encoding="utf-8"?>
<Root>
  <!--  Card Reader/Write
		*  This messge gives details of any exception condition that is detected during card processing. Solicited device
		*  device faults are only reported on Card Before cash transation.
		-->
  <CardReader>
    <!-- Device Identification Graphic. -->
    <Item key="e1" value="D" size="1" restriction="Mandatory" />
    <!--   Transaction/Device Status 	
		* '1'  -  The cardholder did not take his card within the allowed time and it was captured or jammed.
		* '2'  -  The mechanism failed to eject the card and it was captured or jammed.
		* '3'  -  The mechanism failed to update the requested tracks on the card.
        * '4'  -   Invalid track data was received from central.
		-->
    <Item key="e2" value="[Device.CardReader.DevStatus]" size="1" restriction="Mandatory" />
    <!-- Field Separator  -->
    <Item key="[FS]" value="[FS]" size="1" restriction="Mandatory" />
    <!--  Error Severity. -->
    <Item key="e3" value="[Device.CardReader.Fitness]" size="1-2" restriction="Mandatory" />
    <!-- Field Separator  -->
    <Item key="[FS]" value="[FS]" size="1" restriction="Mandatory" />
    <!--  Diagnostic Status.Used for logging errors. The length of the field is variable(because it is hardware-dependent) and may be omitted if 
		* if there is no error condition to be reported. The field will always be present if preceded by an error severity field with a value of 1 or greater.
		* There are certain rules which are followed by all devices.
		* Characters 1 and 2 contain a main error status value. (M-Status) in the range 0 -99, transmitted as 2 characters which give the decimal representation.
		* of the M-Status value.
		* M-Status is used mainly as an error log to assist machine servicing. It may also be used in a transaction log to supplementTransaction status or Device.
		* status information.
        * Characters 3 to n (M-Data) 
		-->
    <Item key="g4" value="[Device.CardReader.DiagnosticStatus]" size="var" restriction="Optional" />
    <!-- Field Separator  -->
    <Item key="[FS]" value="[FS]" size="1" restriction="Mandatory" />
    <!--  Suplies Status. Contains information related to the state of supplies (paper, currency, magnetic cards, envelopes, inkwells, documents)
		 * in the terminal. This field contains one character for each supplies container managed by the device.Each character is always coded in the same 
		 * in same way.
		 *  This is a single character field indicating the state of the card capture bin.
		 *  '0'  - No new state
		 *  '1'  - No overfill condition (capture bin).
		 *  '4'  - Overfill condition (capture bin).
		-->
    <Item key="g5" value="[Device.CardReader.SuppliesStatus]" size="1" restriction="Mandatory" />
  </CardReader>
</Root>