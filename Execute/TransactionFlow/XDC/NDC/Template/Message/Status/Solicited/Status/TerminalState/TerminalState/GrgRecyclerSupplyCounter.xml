		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="o" value="[GrgRecycler.GRGSupplyCounters.NotesMixed.NumOfNotesId]" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="p" value="[GrgRecycler.GRGSupplyCounters.NotesMixed.NotesIdAndCountNums]" size="1" restriction="Mandatory"/>
