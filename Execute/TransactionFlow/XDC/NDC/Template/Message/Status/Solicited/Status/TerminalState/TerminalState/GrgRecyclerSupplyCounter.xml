<?xml version="1.0" encoding="utf-8"?>
<Root>
	<GrgRecyclerSupplyCounter>
		<!--  Send Supply Counters for GRG recycler
		*  This solicited status message is sent to central terminal command message ( a command code of '5'). 
		-->
		<Item key="g" value="s" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="h" value="[GrgRecycler.GRGSupplyCounters.NumberOfCashInTransactions]" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="i" value="[GrgRecycler.GRGSupplyCounters.NumberOfRetractOperations]" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="j1" value="[GrgRecycler.GRGSupplyCounters.LoadNotesInCassettes.Type1]" size="1" restriction="Mandatory"/>
		<Item key="j2" value="[GrgRecycler.GRGSupplyCounters.LoadNotesInCassettes.Type2]" size="1" restriction="Mandatory"/>
		<Item key="j3" value="[GrgRecycler.GRGSupplyCounters.LoadNotesInCassettes.Type3]" size="1" restriction="Mandatory"/>
		<Item key="j4" value="[GrgRecycler.GRGSupplyCounters.LoadNotesInCassettes.Type4]" size="1" restriction="Mandatory"/>
