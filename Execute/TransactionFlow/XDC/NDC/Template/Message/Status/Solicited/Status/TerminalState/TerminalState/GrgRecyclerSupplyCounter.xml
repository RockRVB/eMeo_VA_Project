		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="k1" value="[GrgRecycler.GRGSupplyCounters.RemainNotesInCassettes.Type1]" size="1" restriction="Mandatory"/>
		<Item key="k2" value="[GrgRecycler.GRGSupplyCounters.RemainNotesInCassettes.Type2]" size="1" restriction="Mandatory"/>
		<Item key="k3" value="[GrgRecycler.GRGSupplyCounters.RemainNotesInCassettes.Type3]" size="1" restriction="Mandatory"/>
		<Item key="k4" value="[GrgRecycler.GRGSupplyCounters.RemainNotesInCassettes.Type4]" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="l1" value="[GrgRecycler.GRGSupplyCounters.RejectNotesInCassettes.Type1]" size="1" restriction="Mandatory"/>
		<Item key="l2" value="[GrgRecycler.GRGSupplyCounters.RejectNotesInCassettes.Type2]" size="1" restriction="Mandatory"/>
		<Item key="l3" value="[GrgRecycler.GRGSupplyCounters.RejectNotesInCassettes.Type3]" size="1" restriction="Mandatory"/>
		<Item key="l4" value="[GrgRecycler.GRGSupplyCounters.RejectNotesInCassettes.Type4]" size="1" restriction="Mandatory"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<Item key="m1" value="[GrgRecycler.GRGSupplyCounters.DispensedNotesInCassettes.Type1]" size="1" restriction="Mandatory"/>
		<Item key="m2" value="[GrgRecycler.GRGSupplyCounters.DispensedNotesInCassettes.Type2]" size="1" restriction="Mandatory"/>
		<Item key="m3" value="[GrgRecycler.GRGSupplyCounters.DispensedNotesInCassettes.Type3]" size="1" restriction="Mandatory"/>
		<Item key="m4" value="[GrgRecycler.GRGSupplyCounters.DispensedNotesInCassettes.Type4]" size="1" restriction="Mandatory"/>
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
