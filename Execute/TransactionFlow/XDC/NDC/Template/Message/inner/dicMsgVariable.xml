				<Item size="1" key="CassetteType4" value="4"/>
				<Item size="1" key="CassetteType5" value="4"/>
				<Item size="1" key="CassetteType6" value="4"/>
				<Item size="1" key="CassetteType7" value="4"/>
			</Fitness>
