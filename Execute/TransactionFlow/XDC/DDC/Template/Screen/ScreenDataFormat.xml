<?xml version="1.0" encoding="utf-8"?>
<Root>
	<!-- 
	 * Main control character definition for screen script
	 * [1] The control character of screen script 
	 -->
	<ControlCharacter>
		<Item key="[0x08]" value="BackCursorOnePos" name="BS" existSub="0" description="Moves the cursor back one position"/>
		<Item key="[0x0D]" value="FirstPosInCurrentRow" name="CR" existSub="0" description="Moves the cursor to the first position in the current row."/>
		<Item key="[0x0C]" value="ClearScr" name="FF" existSub="0" description="Clear the screen and position in the cursor to position @,@ on the display grid."/>
		<Item key="[0x09]" value="ShowTrack1" name="HT" existSub="0" description="Causes the name encoded on track 1 of the card to be displayed"/>
		<Item key="[0x0A]" value="CurColumnNextRow" name="LF" existSub="0" description="Moves the cursor to the current column in the next row"/>
		<Item key="[0x0F]" value="SetPosition" name="SI" existSub="0" description="Sets the cursor to the position by next two characters"/>
		<Item key="[0x0E]" value="InsertScrOrResFile" name="SO" existSub="0" description="Insert nested screen(maximum 5 levels) or resource file"/>
		<Item key="[0x0B]" value="SecondaryCharSet" name="VT" existSub="0" description="Set the secondary character set for following next character"/>
		<Item key="[0x1B]" value="SpecialFeature" name="ESC" existSub="1" description="Enable video. Shows the screen display"/>
	</ControlCharacter>
	<!--
	 * Sub control character definition for screen special features
	 * [1] The control character of screen script 
	 * [2] The field "mainKey" map to the ControlCharacter field "key"
	 -->
	<SpecialFeature>
		<Item key="IconAnimation" introducer0="[0x1B]" introducer1="A" identifier="0"/>
		<Item key="DisplayBufContent" introducer0="[0x1B]" introducer1="B" identifier="0"/>
		<Item key="SelectColor" introducer0="[0x1B]" introducer1="C" identifier="0"/>
		<Item key="AnimationDelay" introducer0="[0x1B]" introducer1="D" identifier="0"/>
		<Item key="SelectFont" introducer0="[0x1B]" introducer1="F" identifier="0"/>
		<Item key="SelCharSetAndDisplayMode" introducer0="[0x1B]" introducer1="G" identifier="0"/>
		<Item key="SelectForegroundColor" introducer0="[0x1B]" introducer1="H" identifier="0"/>
		<Item key="InsertScr" introducer0="[0x1B]" introducer1="I" identifier="0"/>
		<Item key="UseColorWheel" introducer0="[0x1B]" introducer1="J" identifier="0"/>
		<Item key="InitiateScrolling" introducer0="[0x1B]" introducer1="K" identifier="0"/>
		<Item key="SetLanguageBank" introducer0="[0x1B]" introducer1="L" identifier="0"/>
		<Item key="ChangeResolution" introducer0="[0x1B]" introducer1="M" identifier="0"/>
		<Item key="SelectPaletteRegisters" introducer0="[0x1B]" introducer1="N" identifier="0"/>
		<Item key="SelectDACSetup" introducer0="[0x1B]" introducer1="O" identifier="0"/>
		<Item key="DisplayIcon" introducer0="[0x1B]" introducer1="P" identifier="0"/>
		<Item key="DisplayCheckImg" introducer0="[0x1B]" introducer1="Q" identifier="0"/>
		<Item key="RepeatCell" introducer0="[0x1B]" introducer1="R" identifier="0"/>
		<Item key="TileNoAddressArea" introducer0="[0x1B]" introducer1="T" identifier="0"/>
		<Item key="TileRectArea" introducer0="[0x1B]" introducer1="U" identifier="0"/>
		<Item key="DisplayBufContentV" introducer0="[0x1B]" introducer1="V" identifier="0"/>
		<Item key="SelectBlinking" introducer0="[0x1B]" introducer1="W" identifier="0"/>
		<Item key="PositionCursor" introducer0="[0x1B]" introducer1="X" identifier="0"/>
		<Item key="SelectSpecialEffectTime" introducer0="[0x1B]" introducer1="Y" identifier="0"/>
		<Item key="SelectTouchScrTemplate" introducer0="[0x1B]" introducer1="ZC" identifier="0"/>
		<Item key="DefineTouchScrConfigData" introducer0="[0x1B]" introducer1="ZD" identifier="0"/>
		<Item key="TouchScrConfigData" introducer0="[0x1B]" introducer1="ZE" identifier="0"/>
		<Item key="DisplayFLCAnimation" introducer0="[0x1B]" introducer1="ZF" identifier="0"/>
		<Item key="DisplayTouchScrBtn" introducer0="[0x1B]" introducer1="ZI" identifier="0"/>
		<Item key="DisplayOutTouchScrBtn" introducer0="[0x1B]" introducer1="ZO" identifier="0"/>
		<Item key="MediaPlayerControl" introducer0="[0x1B]" introducer1="ZU" identifier="0"/>
		<Item key="MpegSetupPlay" introducer0="[0x1B]" introducer1="ZU&quot;MPEGPlay&quot;" identifier="0"/>
		<Item key="ScreenMarker" introducer0="[0x1B]" introducer1="ZV&quot;ScrnMark&quot;" identifier="0"/>
		<Item key="DateTimeTemplate" introducer0="[0x1B]" introducer1=":" identifier="0"/>
		<Item key="FadeOutTransition" introducer0="[0x1B]" introducer1="&lt;" identifier="0"/>
		<Item key="ChangeRowSize" introducer0="[0x1B]" introducer1="=" identifier="0"/>
		<Item key="FadeInTransition" introducer0="[0x1B]" introducer1="&gt;" identifier="0"/>
		<Item key="SpriteAnimation" introducer0="[0x1B]" introducer1="?" identifier="0"/>
		<Item key="ViewOfDepositCheck" introducer0="[0x1B]" introducer1="@" identifier="0"/>
		<Item key="ChangeDisplayInIdle" introducer0="[0x1B]" introducer1="[" identifier="z"/>
	</SpecialFeature>
	<!-- 
	 * The format of sub-control character definition for screen special features
	 -->
	<SubCtrFormat>
		<!-- The definition of Icon Animation-->
		<IconAnimation>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="A" size="1" identifier="1"/>
			<Item key="2" value="[StartIconNum]" size="3" setValue="1"/>
			<Item key="3" value="[NumOfIcon]" size="1" setValue="1"/>
			<Item key="4" value="[DelayOfIconAniDisplay]" size="3" setValue="1"/>
		</IconAnimation>
		
		<!-- The definition of Display Buffer Content-->
		<DisplayBufContent>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="B" size="1" identifier="1"/>
			<Item key="2" value="[DisplayBufId]" size="3" setValue="1"/>
		</DisplayBufContent>
		
		<!-- The definition with format of sub section "SelectColor" -->
		<SelectColor>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="C" size="1" identifier="1"/>			
			<Item key="2" value="[BackgroundValue]" size="1" setValue="1"/>
			<Item key="3" value="[ForegroundValue]" size="1" setValue="1"/>
		</SelectColor>
		
		<!-- The definition with format of sub section "SelectColor Format" -->
		<SelectColor01>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="C" size="1" identifier="1"/>
			<Item key="2" value="Z" size="1" identifier="1"/>
			<Item key="3" value="[BackgroundRedValue]" size="3" setValue="1"/>
			<Item key="4" value="[BackgroundGreenValue]" size="3" setValue="1"/>
			<Item key="5" value="[BackgroundBlueValue]" size="3" setValue="1"/>
			<Item key="6" value="[ForegroundRedValue]" size="3" setValue="1"/>
			<Item key="7" value="[ForegroundGreenValue]" size="3" setValue="1"/>
			<Item key="8" value="[ForegroundBlueValue]" size="3" setValue="1"/>
		</SelectColor01>
		
		<!-- The definition with format of sub section "AnimationDelay" -->
		<AnimationDelay>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="D" size="1" identifier="1"/>
			<Item key="2" value="[DelayOfAnimation]" size="3" setValue="1"/>
		</AnimationDelay>
		
		<!-- The definition with format of sub section "SelectFont" -->
		<SelectFont>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="F" size="1" identifier="1"/>
			<Item key="2" value="[CharacterSet]" size="1"  setValue="1"/>
			<!-- 
			[0] If the length of the font name is less than 2, should be 
				valid from 0 - 7, E, F, G, and @
            [1] If the lenght of the font name is greater than 1, should be
				the font name of any trueType or openType font 
			-->
			<Item key="3" value="[FontName]" size="var" setValue="1" separator = "&quot;"/>
			<!-- 
			[0] If the length of the font name is less than 2, should be 
				valid from normal, blinking, inverse, or blinking inverse)
            [1] If the lenght of the font name is greater than 1, should be
				the desired point size of the font 
			-->			
			<Item key="4" value="[DisplayMode]" size="1" setValue="1" />
			<Item key="5" value="[EncodingType]" size="0" setValue="1" />
			<Item key="6" value="[FontSize]" size="0" setValue="1" />
			<Item key="7" value="[PureText]" size="var" setValue="1" />
		</SelectFont>
		
		<!-- The definition with format of sub section "SelCharSetAndDisplayMode" -->
		<SelCharSetAndDisplayMode>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="G" size="1" identifier="1"/>
			<!--
			 0 			 - Basic (standard and alternate character sets)
			 1 			 - Heivetica character set
			 2 through 7 -  Icon character sets
			-->
			<Item key="2" value="[CharSet]" size="1" setValue="1"/>
			<!--
			 0 - Normal
			 1 - Blinking
			 2 - Inverse video
			 3 - Blinking and inverse video
			-->			
			<Item key="3" value="[DisplayMode]" size="1" setValue="1"/>
		</SelCharSetAndDisplayMode>
		
		<!-- The definition with format of sub section "SelectForegroundColor" -->
		<SelectForegroundColor>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="H" size="1" identifier="1"/>
			<Item key="2" value="[DACColor]" size="3" setValue="1"/>
		</SelectForegroundColor>
		
		
		<!-- The definition with format of sub section "UseColorWheel" -->
		<UseColorWheel>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="J" size="1" identifier="1"/>
			<Item key="2" value="[ScrBlinkColorCtrCmd]" loopIdentifer=""  maxLoop="20"  size = "3" setValue="1"/>
			<Item key="3" value="[0x1B]" size="6"	identifier="1"/>
		</UseColorWheel>
		
		<!-- The definition with format of sub section "InitiateScrolling" -->
		<InitiateScrolling>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="K" size="1" identifier="1"/>
			<!-- 
			[U] - Up
			[D] - Down
			[L] - Left
			[R] - Right
			 -->
			<Item key="2" value="[ScrollDirection]" size="1" setValue="1"/>
			<Item key="3" value="[ScrollScr]" size="3" setValue="1"/>
			<Item key="4" value="[ScrollTopRow]" size="1" setValue="1"/>
			<Item key="5" value="[ScrollBotttomRow]" size="1" setValue="1"/>
			<Item key="6" value="[ScrollDelay]" size="3" setValue="1"/>
		</InitiateScrolling>
		
		
		<!-- The definition with format of sub section "SetLanguageBank" -->
		<SetLanguageBank>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="L" size="1" identifier="1"/>
			<Item key="2" value="[LanguageBankNum]" size="3" setValue="1"/>
		</SetLanguageBank>
		
		<!-- The definition with format of sub section "ChangeResolution" -->
		<ChangeResolution>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="M" size="1" identifier="1"/>
			<!-- 
			00 - 640  * 480 16 Colors
			01 - 320  * 240 256 Colors	
			02 - 320  * 200 256 Colors	
			03 - 640  * 480 256 Colors	
			04 - 1024 * 768 256 Colors	
			05 - 800  * 600 256 Colors	
			-->
			<Item key="2" value="[ResolutionIndex]" size="2" setValue="1"/>
		</ChangeResolution>
		
		<!-- The definition with format of sub section "SelectPaletteRegisters" -->
		<SelectPaletteRegisters>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="N" size="1" identifier="1"/>
			<!-- Custom Palette. 
			Create a palette file to set up a custom palette for 16-color icons.
			-->
			<Item key="2" value="[CustomPalette]" size="3" setValue="1"/>
		</SelectPaletteRegisters>
		
		<!-- The definition with format of sub section "SelectDACSetup" -->
		<SelectDACSetup>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="O" size="1" identifier="1"/>
			<!-- DAC setup numbers range from 256 through 999 -->
			<Item key="2" value="[DACSetupNum]" size="3" setValue="1"/>
		</SelectDACSetup>
		
		<!-- The definition with format of sub section "DisplayIcon" -->
		<DisplayIcon>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="P" size="1" identifier="1"/>
			<!-- Icon name from 000 through 999 -->
			<Item key="2" value="[IconName]" size="3" setValue="1"/>
			<!-- 
			0 - Normal Video
			1 - Blinking Video
			2 - Inverse video
			3 - Blinking inverse video
			4 - Sprinke image (VGA Plus only)
			5 - Wipe image (VGA Plus only)
			-->
			<Item key="3" value="[IconShownMode]" size="1" setValue="1"/>
		</DisplayIcon>
		
		<!-- The definition with format of sub section "DisplayCheckImg" -->
		<DisplayCheckImg>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="Q" size="1" identifier="1"/>
		</DisplayCheckImg>
		
		<!-- The definition with format of sub section "RepeatCell" -->
		<RepeatCell>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="R" size="1" identifier="1"/>
			<Item key="2" value="[RepeatTimes]" size="3" setValue="1"/>
			<Item key="3" value="[RepeatBackgroundColor]" size="1" setValue="1"/>
			<Item key="4" value="[RepeatForegroundColor]" size="1" setValue="1"/>
			<Item key="5" value="[CellValue]" size="1" setValue="1"/>
		</RepeatCell>
		
		<!-- The definition with format of sub section "TileNoAddressArea" -->
		<TileNoAddressArea>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="T" size="1" identifier="1"/>
			<Item key="2" value="[TileBackgroundColor]" size="1" setValue="1"/>
			<Item key="3" value="[TileForegroundColor]" size="1" setValue="1"/>
			<Item key="4" value="[CellValue]" size="1" setValue="1"/>
		</TileNoAddressArea>		

		<!-- The definition with format of sub section "TileRectArea" -->
		<TileRectArea>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="U" size="1" identifier="1"/>
			<Item key="2" value="[UpperRow]" size="1" setValue="1"/>
			<Item key="3" value="[UpperColumn]" size="1" setValue="1"/>
			<Item key="4" value="[LowerRow]" size="1" setValue="1"/>
			<Item key="5" value="[LowerColumn]" size="1" setValue="1"/>
			<Item key="6" value="[TileBackgroundColor]" size="1" setValue="1"/>
			<Item key="7" value="[TileForegroundColor]" size="1" setValue="1"/>
			<Item key="8" value="[CellValue]" size="1" setValue="1"/>
		</TileRectArea>
		
		<!-- The definition with format of sub section "DisplayBufContent" -->
		<DisplayBufContentV>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="V" size="1" identifier="1"/>
			<!-- valid value A through Z 
				 or 256 to 355.
			-->
			<Item key="2" value="[BufName]" size="3" setValue="1"/>
			<Item key="3" value="[DisplayTemplateNum]" size="2" setValue="1"/>
		</DisplayBufContentV>
		
		<!-- The definition with format of sub section "SelectBlinking" -->
		<SelectBlinking>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="W" size="1" identifier="1"/>
			<Item key="2" value="[UpperRow]" size="1" setValue="1"/>
			<Item key="3" value="[UpperColumn]" size="1" setValue="1"/>
			<Item key="4" value="[LowerRow]" size="1" setValue="1"/>
			<Item key="5" value="[LowerColumn]" size="1" setValue="1"/>	
			<Item key="6" value="[BlinkRate]" size="1" setValue="1"/>
		</SelectBlinking>
		
		<!-- The definition with format of sub section "PositionCursor" -->
		<PositionCursor>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="X" size="1" identifier="1"/>
			<!-- The range of XXXX is 0 through 9999 -->
			<Item key="2" value="[xCoordinate]" size="4" setValue="1"/>
			<!-- The range of YYYY is 0 through 9999 -->
			<Item key="3" value="[yCoordinate]" size="4" setValue="1"/>
		</PositionCursor>
		
		<!-- The definition with format of sub section "SelectSpecialEffectTime" -->
		<SelectSpecialEffectTime>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="Y" size="1" identifier="1"/>
			<!--
			[0] > - Adjust time for ESC > control sequence. Default value is 0300 millisecond
			[1] < - Adjust time for ESC < control sequence. Default value is 0300 millisecond 
            [2] P - Adjust time for ESC P control sequence. Default value is 0500 millisecond. This applies to sprinkle and wipe only.
			-->
			<Item key="2" value="[xCoordinate]" size="4" setValue="1"/>
			<!-- The range of YYYY is 0 through 9999 -->
			<Item key="3" value="[yCoordinate]" size="4" setValue="1"/>
		</SelectSpecialEffectTime>

		<!-- The definition with format of sub section "SelectTouchScrTemplate" -->
		<SelectTouchScrTemplate>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZC" size="2" identifier="1"/>
			<!-- The value for current screen is ASCII format (Template number) 	-->
			<Item key="2" value="[TemplateNum]" size="4" setValue="1"/>
			<!-- The range of YYYY is 0 through 9999 -->
			<Item key="3" value="[yCoordinate]" size="4" setValue="1"/>
		</SelectTouchScrTemplate>

		
		<!-- The definition with format of sub section "DefineTouchScrConfigData" -->
		<DefineTouchScrConfigData>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZD" size="2" identifier="1"/>
			<!-- Function Key (Refer to the following table) -->
			<Item key="2" value="[FunctionKey]" size="2" setValue="1"/>			
			<Item key="3" value="[xLowCoordinate]" size="4" setValue="1"/>
			<Item key="4" value="[xHighCoordinate]" size="4" setValue="1"/>
			<Item key="5" value="[yLowCoordinate]" size="4" setValue="1"/>
			<Item key="6" value="[yHigCoordinate]" size="4" setValue="1"/>
			<Item key="7" value="[IconNum]" size="4" setValue="1"/>
		</DefineTouchScrConfigData>
		
		<!-- Touch Screen Configuration Data -->
		<TouchScrConfigData>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZE" size="2" identifier="1"/>
			<!-- Parameter is the template number  -->
			<Item key="2" value="[TemplateNum]" size="3" setValue="1"/>
			<Item key="3" value="[FileName]" size="var" setValue="1"/>	
		</TouchScrConfigData>
		
		<!-- Display FLC/FLI Animation -->
		<DisplayFLCAnimation>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZF" size="2" identifier="1"/>
			<Item key="2" value="[FileName]" size="var" setValue="1"/>			
			<!-- 
             W - A value of W indicates that VGA Plus displays the animated graphic file once. Wait for
				 it to complete, then continue screen processing.
             R - A value of R indicates that VGA Plus displays the animated graphic file repeatedly
				 until encoutering an ESC M or FF control sequence. Continue screen processing while
				 the animation is active
			-->
			<Item key="3" value="[AValueOfVGA]" size="1" setValue="1"/>
			<Item key="4" value="[xCoordinate]" size="4" setValue="1"/>
			<Item key="5" value="[yCoordinate]" size="4" setValue="1"/>
		</DisplayFLCAnimation>

		<!-- Media Player Control -->
		<MediaPlayerControl>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZU&quot;MPEGPlay&quot;" size="12" identifier="1"/>
			<Item key="2" value="1" size="1" identifier="1"/>
			<!-- Play on or off switch
			0 - Off (set up MPEG window but do not begin play)
			1 - On  (set up MPEG window and begin play immediately)
			-->
			<Item key="3" value="[CtrParameter]" size="1" setValue="1"/>
			<Item key="4" value="[FileName]" size="var" setValue="1" separator = "&quot;"/>
			<Item key="5" value="[xCoordinate]" size="4" setValue="1"/>
			<Item key="6" value="[yCoordinate]" size="4" setValue="1"/>
			<Item key="7" value="[HeightOfMpeg]" size="4" setValue="1"/>
			<Item key="8" value="[WidthOfMpeg]" size="4" setValue="1"/>
			<!-- Colorkey state:
			0 - Disabled
			1 - Enabled, with user colorkey management
			2 - Enabled, with automatic colorkey management
            -->
			<Item key="9" value="[ColorkeyState]" size="1" setValue="1"/>
			<Item key="10" value="[ColorPaletteIndex]" size="3" setValue="1"/>
			<Item key="11" value="[PlayMode]" size="1" setValue="1"/>
		</MediaPlayerControl>		

		<!-- Screen Marker -->
		<ScreenMarker>
			<Item key="0" value="[0x1B]" size="6" identifier="1"/>
			<Item key="1" value="ZV" size="2" identifier="1"/>
			<Item key="2" value="[UrlPara]" size="var" setValue="1"/>
			<Item key="3" value="[Coordinate]" size="4" setValue="1"/>
			<!-- 
			T - Positions the browser window along the top edge of the sceen, with a height ssss
			B - Positions the browser window along the bottom edge of the screen, with a height ssss
			L - Positions the browser window along the left edge of the screen, with a width ssss
			R - Positions the browser window along the right edge of the screen, with a width ssss
			F - Displays a fullscreen browser window, where the size is assumed to be the entire screen, and
				the parameter ssss is ignored.
			M - Maintains the currently-displayed browser window without reloading the web page or changing its size
                (underlying non-browser screen data is still processed, even when the browser window is a full screen window).
				If a browser window is not currently visible, the terminal ignores this control sequence.Although p is the 
				only parameter that is processed,all the parameters must be present to ensure correct parsing of the control 
				sequence.
			-->
			<Item key="4" value="[Position]" size="1" setValue="1"/>
			<!-- The number of seconds to wait for a URL to successfully load. -->
			<Item key="5" value="[NumOfSeconds]" size="3" setValue="1"/>
			<!-- A backup screen number must be provided for fullscreen browser windows (when the value of p is F).-->
			<Item key="6" value="[BakScrNum]" size="3" setValue="1"/>
		</ScreenMarker>
		
		<!-- The definition with format of sub section "ChangeDisplayInIdle" -->
		<ChangeDisplayInIdle>
			<Item key="0" value="[0x1B]" size="6"	identifier="1"/>
			<Item key="1" value="[" size="1"	identifier="1"/>
			<Item key="2" value="[Interval]" size="3" setValue="1"/>
			<Item key="3" value="z" size="1"	identifier="1"/>
		</ChangeDisplayInIdle>
		
		<!-- The definition with format of sub section "ChangeColorSetting" -->
		<ChangeColorSetting>
			<Item key="0" value="[0x1B]" size="6"	identifier="1"/>
			<Item key="1" value="[" size="1"	identifier="1"/>
			<Item key="2" value="[Value1]" size="2" setValue="1"/>
