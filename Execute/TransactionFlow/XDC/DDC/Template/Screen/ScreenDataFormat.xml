	<!-- 
 * FDK shifting function, defines the Screen dislpay position of each FDK key after shifting.
 * IsEnable is the function switch, 0 is off and 1 is on.
 * Donnot change the key name for each FDK key, it must keep the same with protocol
 * if shifting is enabled, please change the FDKTouchScr to the same value
 -->
		<FDKShifting>
			<Item key="IsEnable" value = "0"/>
			<Item key="F" value="LeftFDK1" startRow="H" endRow="I" startColumn="@" endColumn="3"/>
			<Item key="G" value="LeftFDK2" startRow="K" endRow="L" startColumn="@" endColumn="3"/>
