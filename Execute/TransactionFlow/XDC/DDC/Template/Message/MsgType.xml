<?xml version="1.0" encoding="utf-8"?>
<Root>
	<!-- Mode  Property
		* The bit value of  for each key value. 
		* The value of key is bit value, and the key is only 0 and 1.
		*  If the ModeSwitch is '0011', the condiction of swithc will be enabled in "OutOfService" and "InService" mode
	-->
	<ModeSwich>
		<!--  Message will be accept to be sent or received in out-of-service mode  -->
		<Item key="0" value="OutOfService"/>
		<!--  Message will be accept to be sent or received in Maintenance  mode  -->
		<Item key="1" value="InMaintenance"/>
		<!--  Message will be accept to be sent or received in In-Service  mode  -->
		<Item key="2" value="InService"/>
		<!--  Message will be accept to be sent or received in consumer in progress  mode  -->
		<Item key="3" value="TransactionState"/>
	</ModeSwich>
	<!-- Main configuration -->
	<Main>
		<!--  Terminal to central message  -->
		<Item key="TerminalToCentralMsg" value="1"/>
		<!--  Central to terminal message  -->
		<Item key="CentralToTerminalMsg" value="1"/>
	</Main>
	<!--  Terminal to central messages  -->
	<TerminalToCentralMsg>
	</TerminalToCentralMsg>
