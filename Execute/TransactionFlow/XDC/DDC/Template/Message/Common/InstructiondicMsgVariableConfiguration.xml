	<!--
		Condition in "Function" statement:
        "计算公式"中Condition说明
				<Condition value="[xmlvariable]" operand="ONLINE|BUSY" operator="!match">
					<xmlvariable value="/Root/Device/Information/CashDispenser/@DeviceState" xmldoc="DataCashDispenser.xml"/>
				</Condition>
				1.assign value and operand :
					a.if the value is[xmlvariable*],the following sub-node<xmlvariable* value="xpath" xmldoc="xml fileName" />
					(remark: * can be any character)
					return the value of "xpath" in "xml file name "
					b.if the value is [msgvariable *],the following sub-node<msgvariable* value="the variate from variate pool" />
					return the specific value:"the variate from variate pool"
					c.if the value is[expvariable*],the following sub-node<expvariable * value = calculate sentence" />
					return the value of the calculate sentence
					d.others
					return the string itself's value.
				1.value 和 operand取值：
					a.赋值为[xmlvariable*],后面有子节点<xmlvariable* value="xpath" xmldoc="xml文件名"/>
					(注：* 任意个字符)
					返回"xml文件名"中"xpath"所指的值
                    b.赋值为[msgvariable*],后面有子节点<msgvariable* value="变量池中的变量"/>
					返回"变量池中的变量"的值
					c.赋值为[expvariable*],后面有子节点<expvariable* value="计算式"/>
					返回"计算式"的值
					d.其它
					返回本身字符串的值。
				2.operator's value		
                2.operator 取值  
                a. "==":
                    {
                        return (value == operator);

                    }

                b. "!=":
                    {
                        return (value != operator);

                    }

                c. ">=":
                    {
                        return (int.Parse(value) >= int.Parse(operator));
                    }

                d. "<=":
                    {
                        return (int.Parse(value) <= int.Parse(operator));
                    }

                e. "match":
                    {
                        Regex r = new Regex(operator);  
                        Match m = r.Match(value);  
                        return m.Success;
                    }
                f. "!match":
                    {
                        Regex r = new Regex(operator);
                        Match m = r.Match(value);
                        return !m.Success;
                    }

                g. "&":
					{
						return value & operator
					} 
				3.get the subnode expression attribution statement
					a."B2H"
					the return value transform from binary to decimal
					b."H2B,0,1"					
					the return value transform from decimal to binary ,only return the beginning position for 0, return the character count for 1.
					c.others
					return the expression value. remark:[var] stands for the middle calculate result.
				3.取值子节点中expression 属性说明
                    a."B2H"
       				返回值由二进制转换为十进制返回.
                    b."H2B,0,1"
       				返回值由十进制转换为二进制，并且只返回开始位置为0，返回字符个数为1.
                    c.其它
					返回表达式的值。注：[var]表示中间计算结果。
                4.get the format attribute from subnode statement:
					a."{0:d10}"
					the return value for 10 digit , if not enought 10 digit , using the 0 as prefix ,fill it in the left side.
                4.取值子节点中format 属性说明
					a."{0:d10}"
					返回值为10位，不够10，前面补0.
  

            
	-->

