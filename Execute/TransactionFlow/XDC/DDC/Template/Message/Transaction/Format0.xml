<?xml version="1.0" encoding="utf-8"?>
<Root>
	<Data>
		<!--  Track 2 data. 
		* 	Contains up to 39 characters of track 2 data from the start sentinel to the end sentinel inclusive. (in the range 30 - 3F hex).
		-->
		<Item key="h" value="[Buffer.Track2]" size="0-39" restriction="[OptionCtrl.I_State.EnableTrack2]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!--  Track 3 data. 
		* 	Contains up to 106 characters of track 3 data from the start sentinel to the end sentinel inclusive. (in the range 30 - 3F hex).
		-->
		<Item key="i" value="[Buffer.Track3]" size="0-106" restriction="[OptionCtrl.I_State.EnableTrack3]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!--  Operation Code Data. 
		* 	Contains the data collected in the opration Code buffer as a result of function idsplay keys pressed. 
		* States D, E and Y determine the contents of this field, which idenfiies the transaction selected by cardholder.
		-->
		<Item key="j" value="[Msg.Transaction.OpCode]" size="8" restriction="[OptionCtrl.I_State.EnableOperationCode]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!-- Amount Entry Field
		* Determined by the Amount Entry and Enhanced Amount Entry states. 
		* Data is right-justified with zeros to fill unused positions on the left. 
		* The length is selecte din Configuration Parameters Load message or the Enhanced Configuration Parameters Load message.
		 -->
		<Item key="k" value="[Msg.Transaction.AmoutEntryField]" size="8-12" restriction="[OptionCtrl.I_State.EnableAmount]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!--  PIN Buffer (Buffer A).. 
		* 	Contains a 16-character PIN, encrypted as specified in the FIT, for remote PIN verification.
		-->
		<Item key="l" value="[Buffer.PIN]" size="var(32)" restriction="[OptionCtrl.I_State.FieldID_PIN]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!--  General Purpose Buffer B 
		* 	Contains the keyboard data entered during the information entry state or after receiving an Interactive Transaction
		* Response. The last character in this buffer is a graphic 'T' if the terminal 'time-out' waiting for the cardholder to respond(via keyboard entry) to
		* an interactive transaction response, or a graphic 'E' if the cardholder pressed  the Cancel key. Length is 3-32..
		-->
		<Item key="m" value="[Buffer.B]" size="var(32)" restriction="[OptionCtrl.I_State.FieldID_B]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="Mandatory"/>
		<!--  General Purpose Buffer C
		* 	Contains the keyboard data entered during the information entry state
		-->
		<Item key="n" value="[Buffer.C]" size="0-32" restriction="[OptionCtrl.I_State.FieldID_C]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="[OptionCtrl.I_State.EnableTrack1]"/>
		<!-- Track 1 Identifier. 
		* Identifies data in the next  field as Track 1 data:
		* '1' - Track 1 data
		-->
		<Item key="o" value="1" size="1" restriction="[OptionCtrl.I_State.EnableTrack1]"/>
		<!--  Track 1 data
		* 	Contains up to 78 characters of Track 1 data from the start sentinel to the end sential inclusive. The character range is 20-5F hex.
		-->
		<Item key="p" value="[Buffer.Track1]" size="0-78" restriction="[OptionCtrl.I_State.EnableTrack1]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="[OptionCtrl.Configuration.IDM]"/>
		<!-- Field ID (MICR Data)		-->
		<Item key="q" value="2" size="1" restriction="[OptionCtrl.Configuration.IDM]"/>
		<!--  MICR Data		-->
		<Item key="r" value="[MICRData]" size="4" restriction="[OptionCtrl.Configuration.IDM]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Field ID (Transaction Verification Status Data)		-->
		<Item key="q" value="6" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!--  MICR Data		-->
		<Item key="r" value="[Msg.Transaction.LastFunction.TransactionSerialNumber]" size="4" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r1" value="[Msg.Transaction.LastFunction.Response]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r2" value="[Msg.Transaction.RetractOperation]" size="20" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Group Separator (GS)  -->
		<Item key="r2" value="[GS]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Device ID (Bill Dispenser)  -->
		<Item key="r2" value="DI01" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Record Separator (RS)  -->
		<Item key="r2" value="[RS]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Bill Denomination ID  -->
		<Item key="r2" value="[Msg.Transaction.BillDispenser.Position1.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r2" value="[Msg.Transaction.BillDispenser.Position2.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r2" value="[Msg.Transaction.BillDispenser.Position3.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r2" value="[Msg.Transaction.BillDispenser.Position4.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<Item key="r2" value="[Msg.Transaction.BillDispenser.Position5.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.AFD5HighFeature]"/>
		<!-- Record Separator (RS)  -->
		<Item key="r2" value="[RS]" size="1" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Bills Dispensed Count  -->
		<Item key="r2" value="[Msg.Transaction.LastFunction.NotesDispensed]" size="20" restriction="[Options.F3.TransactionVerificationStatus]"/>
		<!-- Group Separator (GS)  -->
		<Item key="r2" value="[GS]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<!-- Device ID (Coin Dispenser)  -->
		<Item key="r2" value="CN01" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<!-- Record Separator (RS)  -->
		<Item key="r2" value="[RS]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<!-- Coin Denomination ID  -->
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position1.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position2.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position3.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position4.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position5.Demon]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser],[OptionCtrl.Configuration.AFD5HighFeature]"/>
		<!-- Record Separator (RS)  -->
		<Item key="r2" value="[RS]" size="1" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<!-- Coin Dispensed Count  -->
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position1.Dispensed]" size="5" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position2.Dispensed]" size="5" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position3.Dispensed]" size="5" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position4.Dispensed]" size="5" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser]"/>
		<Item key="r2" value="[SupplyCounters.CoinDispenser.Position5.Dispensed]" size="5" restriction="[Options.F3.TransactionVerificationStatus],[OptionCtrl.Configuration.CoinDispenser],[OptionCtrl.Configuration.AFD5HighFeature]"/>
		<Item key="wincoremvdata" value="[Msg.Transaction.WincorDDCEmvBuffer]" size="var" restriction="Optional"/>
		<Item key="r" value="[Msg.Transaction.BufferGroup]" size="var" restriction="Optional"/>
		<!-- Rollover Count -->
		<Item key="[FS]" value="[FS]" size="1" restriction="[Options.F1.AppendRolloverCounts]"/>
		<Item key="r2" value="[Msg.RolloverCount.Position1]" size="5" restriction="[Options.F1.AppendRolloverCounts]"/>
		<Item key="r2" value="[Msg.RolloverCount.Position2]" size="5" restriction="[Options.F1.AppendRolloverCounts]"/>
		<Item key="r2" value="[Msg.RolloverCount.Position3]" size="5" restriction="[Options.F1.AppendRolloverCounts]"/>
		<Item key="r2" value="[Msg.RolloverCount.Position4]" size="5" restriction="[Options.F1.AppendRolloverCounts]"/>
		<Item key="r2" value="[Msg.RolloverCount.Position5]" size="5" restriction="[Options.F1.AppendRolloverCounts],[OptionCtrl.Configuration.CoinDispenser],[OptionCtrl.Configuration.AFD5HighFeature]"/>
		<!-- Field Separator  -->
		<Item key="[FS]" value="[FS]" size="1" restriction="[OptionCtrl.EnableMAC]"/>
		<!--  Message Authentication Code Data. The field contains the calculated value for authentication of this message. -->
		<Item key="x" value="[MAC]" size="8" restriction="[OptionCtrl.EnableMAC]"/>
	</Data>
</Root>
