			<Item key="3" value="PreSetH" size="3" description="Set the specifies bytes of buffer to 'H' according to each bit."/>
			<Item key="4" value="PreSetI" size="3" description="Set the specifies bytes of buffer to 'I' according to each bit"/>
			<Item key="5" value="Reservered" size="3" description="Reservered."/>
			<Item key="6" value="Reservered" size="3" description="Reservered."/>
			<Item key="7" value="Reservered" size="3" description="Reservered"/>
			<Item key="8" value="Reservered" size="3" description="Reservered"/>
