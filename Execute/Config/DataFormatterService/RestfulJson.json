{
  "hostList": [
    {
      "name": "core bank",
      "desc": "VAB Gateway",
      "encoding": "utf-8",
      "server": {
        "host": "10.1.10.33",
        "port": "9999",
        "protocol": "https"
      },
      "head": {
        "method": "post",
        "contentType": "application/json",
        "requestTimeout": "30000",
        "Headers": "authorization={FB_accessToken};Scenes-key={FB_sceneKey}"
      },
      "transactions": [     
		{
          "name": "QueryCustomerInfo",
		  "method": "post",
          "url": "",
          "response": "QueryCustomerInfoResponse",
          "body": {
		    "sessionId":"{VAB_SessionID}",
			"customerId":"{VAB_CustomerId}",
			"transactionType":"{proj_TransType}",
			"currency":"VND",
		  }
        },
        {
          "name": "QueryCustomerInfoResponse",
          "SuccessCode": "0",
          "body": {
            "code": "{this.responsecode}",
            "msg": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        }
      ]
    },
	{
      "name": "VAB Gateway",
      "desc": "VAB Gateway",
      "encoding": "utf-8",
      "server": {
        "host": "192.168.11.7",
        "port": "8089",
        "protocol": "https"
      },
      "head": {
        "method": "post",
        "contentType": "application/json",
        "requestTimeout": "30000"
      },
      "transactions": [     
		{
          "name": "GetQRString",
		  "method": "post",
          "url": "/api/BankService/GetQRString",
          "response": "GetQRStringResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "GetQRStringResponse",
          "SuccessCode": "0",
          "body": {
            "resCode": "{this.responsecode}",
            "resDesc": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "VerifyQR",
		  "method": "post",
          "url": "/api/BankService/VerifyQR",
          "response": "VerifyQRResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "VerifyQRResponse",
          "SuccessCode": "0",
          "body": {
            "resCode": "{this.responsecode}",
            "resDesc": "{this.errordesc}",
            "data": "{proj_response}"
          }
        }
      ]
    }
  ]
}