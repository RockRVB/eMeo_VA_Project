{
  "hostList": [
    {
      "name": "core bank",
      "desc": "VAB Gateway",
      "encoding": "utf-8",
      "server": {
        "host": "192.168.11.7",
        "port": "8089",
        "protocol": "https"
      },
      "head": {
        "method": "post",
        "contentType": "application/json",
        "requestTimeout": "30000",
        "headers": "Authorization= Basic ZXptb2JpbGU6VmFiMjAyNEA="
      },
      "transactions": [     
		{
          "name": "QueryCustomerInfo",
		  "method": "post",
          "url": "/evobank/account/v1/query-list-by-cif",
          "response": "QueryCustomerInfoResponse",
          "body": {
			  "requestId":"{proj_RequestId}",
			  "requestTime":"{proj_RequestTime}",
		      "sessionId":"{VAB_SessionID}",
			  "userId":"{VAB_CustomerId}",
			  "deviceId":"{proj_DeviceId}",
			  "ipAddress":"{proj_IpAddress}",
			  "cifNumber": "{VAB_CustomerId}",
			  "hasSalary": true,
			  "hasOverdraft": true,
			  "hasHouseHold": true
			}
        },
        {
          "name": "QueryCustomerInfoResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        },
		{
          "name": "QueryTransFee",
		  "method": "post",
          "url": "/api/BankService/QueryTransFee",
          "response": "QueryTransFeeResponse",
          "body": {
		  	"requestId":"{proj_RequestId}",
			"requestTime":"{proj_RequestTime}",
		    "sessionId":"{VAB_SessionID}",
			"userId":"{VAB_CustomerId}",
			"deviceId":"{proj_DeviceId}",
			"ipAddress":"{proj_IpAddress}",
			"srcAccountNo":"{proj_AccountNumber}}",
			"srcBranch":"{proj_BranchCode}",
			"amount":"{proj_Amount}}",
			"method":"{proj_TransType}"
		  }
        },
        {
          "name": "QueryTransFeeResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        },
		{
          "name": "GetQRString",
		  "method": "post",
          "url": "/api/BankService/GetQRString",
          "response": "GetQRStringResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "GetQRStringResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "VerifyQR",
		  "method": "post",
          "url": "/api/BankService/VerifyQR",
          "response": "VerifyQRResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "VerifyQRResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "CashWithdrawalNoCardConfirm",
		  "method": "post",
          "url": "/api/BankService/CashWithdrawalNoCardConfirm",
          "response": "CashWithdrawalNoCardConfirmResponse",
          "body": {
			"sessionId":"{VAB_SessionID}",
			"customerId":"{VAB_CustomerId}",
			"accountNumber":"{proj_AccountNumber}}",
			"amount":"{proj_Amount}}",
			"currency":"VND",
			"narrative":"Rut tien mat tu tai khoan",
			"branchCode":"{proj_BranchCode}",
			"fee":"{proj_Fee}",
			"tax":"{proj_Tax}",
			"transactionType":"{proj_TransType}",
			"deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}"
		  }
        },
        {
          "name": "CashWithdrawalNoCardConfirmResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "DepositConfirm",
		  "method": "post",
          "url": "",
          "response": "DepositConfirmResponse",
          "body": {
			"requestId":"{proj_RequestId}",
			"requestTime":"{proj_RequestTime}",
		    "sessionId":"{VAB_SessionID}",
			"userId":"{VAB_CustomerId}",
			"deviceId":"{proj_DeviceId}",
			"ipAddress":"{proj_IpAddress}",
			"stmID":"{proj_STMID}",
			"branchCode":"{proj_BranchCode}",
			"accountNo":"{proj_AccountNumber}}",
			"description":"{proj_Description}",
			"amount":"{proj_Amount}}",
			"feeAmt":"{proj_Fee}",
			"vatAmt":"{proj_Tax}",
			"transactionType":"{proj_TransType}"
		  }
        },
        {
          "name": "DepositConfirmResponse",
          "SuccessCode": "200000",
          "body": {
            "code": "{this.responsecode}",
            "message": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        }
      ]
    }
  ]
}