{
  "hostList": [
    {
      "name": "core bank",
      "desc": "VAB Gateway",
      "encoding": "utf-8",
      "server": {
        "host": "192.168.11.7",
        "port": "8089",
        "protocol": "https"
      },
      "head": {
        "method": "post",
        "contentType": "application/json",
        "requestTimeout": "30000",
        "Headers": "Authorization= Basic ZXptb2JpbGU6VmFiMjAyNEA="
      },
      "transactions": [     
		{
          "name": "QueryCustomerInfo",
		  "method": "post",
          "url": "/api/BankService/QueryCustomerInfo",
          "response": "QueryCustomerInfoResponse",
          "body": {
		    "sessionId":"{VAB_SessionID}",
			"customerId":"{VAB_CustomerId}",
			"transactionType":"{proj_TransType}",
			"currency":"VND",
		  }
        },
        {
          "name": "QueryCustomerInfoResponse",
          "SuccessCode": "0",
          "body": {
            "code": "{this.responsecode}",
            "msg": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        },
		{
          "name": "QueryTransFee",
		  "method": "post",
          "url": "/api/BankService/QueryTransFee",
          "response": "QueryTransFeeResponse",
          "body": {
		    "sessionId":"{VAB_SessionID}",
			"customerId":"{VAB_CustomerId}",
			"accountNumber":"{proj_AccountNumber}}",
			"amount":"{proj_Amount}}",
			"transactionType":"{proj_TransType}",
			"currency":"VND",
		  }
        },
        {
          "name": "QueryTransFeeResponse",
          "SuccessCode": "0",
          "body": {
            "code": "{this.responsecode}",
            "msg": "{this.errordesc}",
            "data": "{FB_jsonrevdata}"
          }
        },
		{
          "name": "GetQRString",
		  "method": "post",
          "url": "/api/BankService/GetQRString",
          "response": "GetQRStringResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "GetQRStringResponse",
          "SuccessCode": "0",
          "body": {
            "resCode": "{this.responsecode}",
            "resDesc": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "VerifyQR",
		  "method": "post",
          "url": "/api/BankService/VerifyQR",
          "response": "VerifyQRResponse",
          "body": {
		    "deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}",
			"transactionType":"{proj_TransType}",
			"sessionId":"{VAB_SessionID}"
		  }
        },
        {
          "name": "VerifyQRResponse",
          "SuccessCode": "0",
          "body": {
            "resCode": "{this.responsecode}",
            "resDesc": "{this.errordesc}",
            "data": "{proj_response}"
          }
        },
		{
          "name": "CashWithdrawalNoCardConfirm",
		  "method": "post",
          "url": "/api/BankService/CashWithdrawalNoCardConfirm",
          "response": "CashWithdrawalNoCardConfirmResponse",
          "body": {
			"sessionId":"{VAB_SessionID}",
			"customerId":"{VAB_CustomerId}",
			"accountNumber":"{proj_AccountNumber}}",
			"amount":"{proj_Amount}}",
			"currency":"VND",
			"narrative":"Rut tien mat tu tai khoan",
			"branchCode":"{proj_BranchCode}",
			"fee":"{proj_Fee}",
			"tax":"{proj_Tax}",
			"transactionType":"{proj_TransType}",
			"deviceId":"{binding=context.TerminalConfig.Terminal.ATMNumber}"
		  }
        },
        {
          "name": "CashWithdrawalNoCardConfirmResponse",
          "SuccessCode": "0",
          "body": {
            "resCode": "{this.responsecode}",
            "resDesc": "{this.errordesc}",
            "data": "{proj_response}"
          }
        }
      ]
    }
  ]
}