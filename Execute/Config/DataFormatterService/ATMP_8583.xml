<?xml version="1.0" encoding="UTF-8"?>
<!--             
标记TransactionFieldConfig包含了报文接口定义的所有的域，域所包含的字段说明如下所示：
Description 			参考《银行卡联网联合技术规范V2.0 第2部分 报文接口规范.pdf》
    
对于指定的交易，如INQ查询交易，需要用到的域，罗列在<INQ>之下，表示INQ交易只使用这些域，其XML结构跟TransactionFieldConfig的一样。
如果在指定交易下，其中的某些域的字段有别于TransactionFieldConfig的定义，可以在指定的交易下，额外列出差异的标识和属性
如果没有额外列出，认为此域的字段跟TransactionFieldConfig的定义一致，没有特殊化。


    // 域结构说明
    public struct tISO8583FileldConfig
    {
        // FieldCheckData 的取值为：
        // 空或不存在时，表示“打包时此域的数据FieldData”与“解包时此域的数据FieldHostData”进行校验
        // 其它情况，表示“解包时此域的数据FieldHostData”与“FieldCheckData配置的数据”进行校验	
        public string FieldCheckData;

        // 此域的默认数据，如果KV中存在则使用KV的数据，否则使用默认数据
        public string FieldDefaultData;

        // 此域的关键字，如果在KV中存在，则会使用KV的数据代替域的默认数据
        public string FieldName;           
      
        // 此域的长度，可以是VAR（表示变长数据，在FeelView中常用），
        // 可以是某个数字（如12，表示长度只能是12，在VarFieldLenType为FIXED下，会执行长度检查）
        // 单位为字节
        public int FieldDataLen;

        // 此域是否可选，如果是，则KV中不存在的话打包时此域会被忽略
        // 如果否，则KV中不存在会报错
        // 默认为否
        public BooleanType FieldIsOptional;

        // 此域的编码方式（BCD或ASCII）
        public ValueCoding FieldDataCoding;

        // 响应报文解包后的数据保存在此域中
        public string FieldHostData;

        // 域ID，在交易打包中经常使用。
        // “BitID是-1，-2等负数的域，与主位图或者扩展位图没有关系，不会在位图上有所体现”
        public int FieldID;

        // 域数据的长度的类型（FIXED或VAR_LL或VAR_LLL）
        public LengthStyle VarFieldLenType;

        // 域数据的长度的编码方式（BCD或ASCII）
        public ValueCoding VarFieldLenCoding;

        // 左填充字符，如果传入的数据的长度少于配置的长度FieldDataLen，则左填充此字符
        public string LeftPadding;

        // 右填充字符，如果传入的数据的长度少于配置的长度FieldDataLen，则右填充此字符
        public string RightPadding;

        // 左删除字符，如果LeftTrim配置有值，则执行左删除
        public string LeftTrim;

        // 右删除字符，如果RightTrim配置有值，则执行右删除
        public string RightTrim;

        // 取子串配置，如"0,20"，表示取最前面的20个字符
        public string SubString;                

        // CheckIsMandatory 的取值为：
        // true时，表示此域必须存在 ，并且需要校验
        // false时，表示此域存在则校验，不存在就不校验
        // no_check时，表示此域不校验
        // 子域不配置此项时，以总域的配置为准，如果总域也没配置此项表示此域不校验 
        public BooleanType CheckIsMandatory;

        // CheckMode 的取值为：
        // int时，表示按数值的方式校验
        // string时，表示按字符串的方式校验
        // 不存在或其它情况时， 表示按字符串的方式校验
        public string CheckMode;

        CanUnpackPartly="1"
        // 部分解包（一般适用于定长报文）
        // 如果配置为1，表示允许部分解包，并在部分解包下可以返回解包成功（就算可能后面的域因为没有数据而返回空，只解出了前面部分的域）
        // 如果配置为0，表示不允许部分解包，只能全部域都解出来才会返回成功
        public bool m_isCanUnpackPartly = false;
    }
    
    注意：FieldName是一个关键字，不能重复！至少在一个交易和相关联的MAC交易中，一定不能重复。
    
  在TransactionFieldConfig增加MaskFieldName="F_PAN|F_BITMAP" 可以在日志中屏蔽指定的域
-->
<Packages>
	<TransactionFieldConfig HeadLength="4" HeadLengthCoding="BCD" BitmapFieldID="1" MaskFieldName="F_PAN|F_POSENTRYMODE|F_POSCONDITIONCODE|F_POSPINCAPTURECODE|F_ACCOUNTNAME|F_SECURITYCONTROLINFO|F_ADDITIONDATA|F_ACCOUNTID1|F_ACCOUNTID2">
		<HeaderFields>
		</HeaderFields>
		<BitmapFields>
			<Field BitID="-1" Description="报文头部">
				<Data FieldName="F_HEADER" FieldDefaultData="0110000000" FieldDataLen="10" FieldDataCoding="ASCII" FieldCheckData=""/>
				<VAR VarFieldLenType="FIXED" VarFieldLenCoding="ASCII"/>
			</Field>
			<Field BitID="0" Description="信息类型标识">
