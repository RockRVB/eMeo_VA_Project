<?xml version="1.0" encoding="UTF-8"?>
<!--                                                                                 
ServiceName：设备的服务名                                                                   
ServerIP：   服务器IP
Port：       服务端口号
ProcessName：双屏程序名称，默认"TwinScreen.exe"
CmdPrefix：  命令前缀，默认"FUN_,MENU_,KEYBOARD_"
Timeout：    超时时间，默认5000ms
BufferSize： 缓冲区大小，默认2048字节  
Config：     配置文件名称         
-->                                                                               
<FlashDevice ServiceName="Flash" ServerIP="127.0.0.1" Port="9001" ProcessName="TwinScreen.exe" CmdPrefix="FUN_,MENU_,KEYBOARD_" Timeout="5000" BufferSize="2048" Config="Config\GeneralConfig.xml"/>
