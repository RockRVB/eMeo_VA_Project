<!--
此XML配置文件用于非WOSA的扩展设备。

如聚宝网络设备接口：
    public  class JuboDeviceWrapper : DeviceServiceWrapperBase
    {
#region instance
        private static JuboDeviceWrapper m_singleDevWrapper= null;
        public static JuboDeviceWrapper Instance
        {
            get
            {
                if (null == m_singleDevWrapper)
                {
                    IDeviceService devService = JuboDevice.Create();
                    if (null!=devService)
                    {
                        devService.Open(".\\Config\\DeviceService\\OtherDevices.xml");
						m_singleDevWrapper = new JuboDeviceWrapper(devService);
                    } 
                }
                return m_singleDevWrapper;
            }
        }
#endregion

