<?xml version="1.0" encoding="UTF-8"?>
<!--ServiceName：           设备的服务名
    ReadTracks ：           读取的磁道标志
    TrackInfoInExt ：       读取的磁道信息是否以拓展的十六进制字符表示，例如"13"表示为"3133",取值为"TRUE"、"FALSE",默认为"FALSE"。掌静脉会用到。
    ErrorCode ：            错误码 用于记录最近一次的设备错误物理码 默认为""，可以不用配置，系统会自己按顺序查找  
-->
<CardReader ServiceName="IDC30" ReadTracks="1,2,3,IC"/>