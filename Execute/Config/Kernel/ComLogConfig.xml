<?xml version="1.0" encoding="UTF-8"?>
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">
	<root>
		<level value="debug" />
	</root>
	<logger name="CDM">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="CashDispenser" />
	</logger>
	<logger name="CIM">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="CashAcceptor" />
	</logger>
	<logger name="DEP30">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="DEP30" />
	</logger>
	<logger name="IDC">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="CardReader" />
	</logger>	
	<!--logger name="JournalPrinter" additivity="false">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="JournalPrinter" />
	</logger-->		
	<logger name="EPP" additivity="false">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="Encryptor" />
	</logger>
	<!--logger name="ReceiptPrinter" additivity="false">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="ReceiptPrinter" />
