		<additivity value="false" />
		<appender-ref ref="TTU" />
	</logger>
	<logger name="VDM" additivity="false">
		<level value="debug" />
		<additivity value="false" />
		<appender-ref ref="VDM" />
	</logger>
	
	 <logger name="PBP" additivity="false">   <!-- PBP 是根据代码中的 this->m_abTrace->ResetTraceName("PBP");来的 -->
      <level value="debug" /> 
      <additivity value="false" />     
     <appender-ref ref="Passbook" /> 
   </logger> 
   <appender name="Passbook" class="org.apache.log4j.DailyRollingFileAppender"> 
     <param name="encoding" value="UTF-8" /> 
     <param name="DatePattern" value="'Log/XFSControl/PASSBOOK_'yyyy-MM-dd'.txt'" /> 
     <param name="Append" value="true" /> 
     <layout class="org.apache.log4j.PatternLayout"> 
       <param name="ConversionPattern" value="%d{HH:mm:ss,SSS} [%t] -- %m%n" /> 
    </layout> 
   </appender>  

   	<appender name="CashDispenser" class="org.apache.log4j.DailyRollingFileAppender">
   		<param name="encoding" value="UTF-8" />
   		<param name="DatePattern" value="'Log/XFSControl/CashDispenser_'yyyy-MM-dd'.txt'" /> 
   		<param name="Append" value="true" />
   		<layout class="org.apache.log4j.PatternLayout">
       		<param name="ConversionPattern" value="%d{HH:mm:ss,SSS} [%t] --  %m%n" />
   		</layout>
   </appender>
   	<appender name="CashAcceptor" class="org.apache.log4j.DailyRollingFileAppender">
