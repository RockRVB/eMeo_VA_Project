<?xml version="1.0" encoding="UTF-8"?>
<MessageCenterServiceConfig>
  <!--Create by hxbo1 -->

  <!--
  sendMode="0"发接，sendMode="1"只发不接
  -->

  <!--默认SessionName-->
  <SessionName>VTMP1</SessionName>

   <!--默认SessionName-->
  <PhotoFolder>D:\Image</PhotoFolder>
  
  <!--报文模板-->
  <MsgModel>

    <!--发往VTMP非中转的报文模板-->
    <PCModel packType="XML">
      <vtm>
        <head></head>
        <body></body>
      </vtm>
    </PCModel>

    <!--发往VTMP中转的报文模板-->
    <PCZZModel packType="XML">
      <root>
        <head></head>
        <body></body>
      </root>
    </PCZZModel>

    <!--发往VTMP中转发往CTS的报文模板-->
    <HCModel packType="FGMsg">
      <SocketFlag></SocketFlag>
      <TradeCode></TradeCode>
      <xmlFlag></xmlFlag>
    </HCModel>
  </MsgModel>

  <!--报文配置-->
  <MsgConfig>
    <!--VTMP管理类交易 Begin-->
    <PinApply sendMode="0" remark="终端密钥申请">
      <Send packModel="PCModel">
        <TradeCode modelTag="vtm/head">8001</TradeCode>
        <ReqTime modelTag="vtm/head" bindvar="jnbank_ReqTime"></ReqTime>
        <ReqDate modelTag="vtm/head" bindvar="jnbank_ReqDate"></ReqDate>
        <CTermId modelTag="vtm/head" bindvar="core_TerminalID"></CTermId>
        <FlowId modelTag="vtm/head" bindvar="jnbank_flowId"></FlowId>
        <DevType modelTag="vtm/body">0</DevType>
        <EncryValue modelTag="vtm/body">vtm.27620013.zpk</EncryValue>
      </Send>
      <Recv packModel="PCModel">
        <RespCode modelTag="vtm/head"></RespCode>
        <RespMsg modelTag="vtm/head" bindvar="core_HostRefuseMessage"></RespMsg>
        <PinKey modelTag="vtm/body" bindvar="jnb_Pinkey"></PinKey>
      </Recv>
    </PinApply>

    <PinConvert remark="终端密钥转PIN">
      <Send packModel="PCModel">
        <TradeCode modelTag="vtm/head">8002</TradeCode>
        <ReqTime modelTag="vtm/head" bindvar="jnbank_ReqTime"></ReqTime>
        <ReqDate modelTag="vtm/head" bindvar="jnbank_ReqDate"></ReqDate>
        <CTermId modelTag="vtm/head" bindvar="core_TerminalID"></CTermId>
		<QueueNo modelTag="vtm/head"></QueueNo>
        <FlowId modelTag="vtm/head" bindvar="jnbank_flowId"></FlowId>
        <zpk1 modelTag="vtm/body">vtm.27620013.zpk</zpk1>
        <zpk2 modelTag="vtm/body">host.0001.zpk</zpk2>
        <Bankcard modelTag="vtm/body" bindvar="core_PAN"></Bankcard>
        <pinBlock1 modelTag="vtm/body" bindvar="core_NewPin"></pinBlock1>
		<DevType modelTag="vtm/body">0</DevType>
      </Send>
      <Recv packModel="PCModel">
        <RespCode modelTag="vtm/head"></RespCode>
        <RespMsg modelTag="vtm/head" bindvar="core_HostRefuseMessage"></RespMsg>
        <pinBlock2 modelTag="vtm/body" bindvar="core_Pin"></pinBlock2>
      </Recv>
    </PinConvert>

	<SignPinConvert remark="签约密钥转PIN">
      <Send packModel="PCModel">
        <TradeCode modelTag="vtm/head">8002</TradeCode>
        <ReqTime modelTag="vtm/head" bindvar="jnbank_ReqTime"></ReqTime>
        <ReqDate modelTag="vtm/head" bindvar="jnbank_ReqDate"></ReqDate>
        <CTermId modelTag="vtm/head" bindvar="core_TerminalID"></CTermId>
		<QueueNo modelTag="vtm/head"></QueueNo>
        <FlowId modelTag="vtm/head" bindvar="jnbank_flowId"></FlowId>
        <zpk1 modelTag="vtm/body">vtm.27620013.zpk</zpk1>
        <zpk2 modelTag="vtm/body">qz.ib.zpk</zpk2>
        <Bankcard modelTag="vtm/body" bindvar="core_PAN"></Bankcard>
        <pinBlock1 modelTag="vtm/body" bindvar="core_NewPin"></pinBlock1>
		<DevType modelTag="vtm/body">0</DevType>
      </Send>
      <Recv packModel="PCModel">
        <RespCode modelTag="vtm/head"></RespCode>
        <RespMsg modelTag="vtm/head" bindvar="core_HostRefuseMessage"></RespMsg>
        <pinBlock2 modelTag="vtm/body" bindvar="core_Pin"></pinBlock2>
      </Recv>
    </SignPinConvert>
	
