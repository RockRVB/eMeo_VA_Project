    <Item key="Request_0" value="Resource\XDC\Voice\Default\DAUDIO01.WAV" valueType="string" />
    <!--GoodBye -->
    <Item key="GoodBye_0" value="Resource\XDC\Voice\Default\DAUDIO08.WAV" valueType="string" />
