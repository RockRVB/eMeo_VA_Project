    <!--Tell the user get the card -->
    <Item key="TakeCard_2" value="Resource\XDC\Voice\Default\DAUDIO02.WAV" valueType="string" />
    <!--Tell the user take the notes when cwd -->
    <Item key="TakeNotes_2" value="Resource\XDC\Voice\Default\DAUDIO02.WAV" valueType="string" />
