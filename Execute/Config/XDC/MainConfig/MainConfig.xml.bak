      <Item key="9F37" value="" />
    </SolicitedMsgTagValue>
    <OperationIdentifier>
      <Item key="Identifier" value="SV077" />
      <Item key="TransReqFromIni" value="Data_TransReq" />
      <Item key="ReadBReqFromIni" value="DataObjForCompData" />
      <!--the type of searching tag, default is 1 -->
      <Item key="SearchTagTyep" value="1" />
    </OperationIdentifier>
    <!--Add and set Tag to EMV kernel -->
    <AddSetTag>
      <Item key="TagName" value="9F03,9F02,9F34,9C,57,5A,5F2A,5F34,82,8C,95,9A,9F06,9F10,9F1A,9F26,9F27,9F33,9F36,9F37" />
      <!--match with TagValue,separate with ','  for example "9F37,9F53" -->
      <Item key="TagValue" value="000000000000,,,,,,,,,,,,,,,,,,," />
      <!--match with TagName,separate with ','  for example "0000,0000" -->
    </AddSetTag>
    <NormalParam>
      <!--Amount Decimal Count 0,1 or 2-->
      <Item key="AmountDecimalCount" value="2" valueType="int" />
      <!--PartialUpdateAID 0 : Full Update, delete all perivous resgistered AID     1: Partial Update, add new AID and modified ones-->
      <Item key="PartialUpdateAID" value="1" valueType="string" />
    </NormalParam>
    <NDCEMVConfig>
      <!--Default AID-->
      <Item key="DefaultAID" value="A000000541" />
    </NDCEMVConfig>
  </EMVData>
  <VoicePlay>
    <!--Tell the user input password -->
    <Item key="InputPassWord_0" value="Resource\XDC\Voice\Default\DAUDIO07.WAV" valueType="string" />
    <!--Tell the user get the card -->
    <Item key="TakeCard_0" value="Resource\XDC\Voice\Default\DAUDIO03.WAV" valueType="string" />
    <!--Tell the user take the notes when cwd -->
    <Item key="TakeNotes_0" value="Resource\XDC\Voice\Default\DAUDIO06.WAV" valueType="string" />
    <!--Tell the user select the funtion  -->
    <!--<Item key="SelectFuntion_0" value="Resource\XDC\Voice\Default\DAUDIO04.WAV" valueType="string" />-->
