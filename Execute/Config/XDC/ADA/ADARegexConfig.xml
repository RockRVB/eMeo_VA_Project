				<!-- <AudioFile  audioFileName="pause_100ms.wav"/> -->
				<!-- <AudioFile  audioFileName="has.wav"/> -->
				<!-- <Numbers /> -->
				<!-- <AudioFile  audioFileName="pause_200ms.wav"/> -->
			<!-- </DepositDetailTemplate> -->
			<!-- <AudioFile  audioFileName="total_amount.wav"/> -->
			<!-- <AudioFile  audioFileName="is.wav"/> -->
			<!-- <AudioFile  audioFileName="pause_100ms.wav"/> -->
			<!-- <DepositTotalAmount sourceScreenID="DEP"/> -->
			<!-- <AudioFile  audioFileName="USD.wav"/> -->
		<!-- </Screen> -->
	</DynamicScreenAudio>
	
	<!-- <Text content="&lt;break strength='medium'/&gt;"/> -->
	<!-- <Text content="&lt;silence msec='500'/&gt;"/> -->
	
<!--
    这里配置屏幕号对应的 ADA TXT 文本拼接后播放配置，Screen节点中的screenID代表在显示哪个根屏幕号的时候会根据这里的设置进行 ADA TXT 文本的拼接播放，其中子节点可以配置5种：
		1、Text(静态文本)子节点
			content：需要播放的静态文本内容。可以是符合微软 SSML 格式标准的内容，如【&lt;silence msec='500'/&gt;】是【停顿500毫秒】的作用，其中【&lt;】和【&gt;】是小于号和大于号的转义符，请注意特殊字符的转义；

		2、DynamicNumber(屏幕脚本中主机下发的动态数字(例如金额)，按照带有数字单位的方式进行播放)子节点
			sourceScreenID：动态数字(例如金额)数据来源屏幕号；
			regexPattern：用来从数据来源屏幕号中提取出动态数字(例如金额)字符串的正则表达式匹配模式串。

		3、DynamicNumberSpeakOneByOne(屏幕脚本中主机下发的动态数字(例如卡号)，按照一个一个数字的方式进行播放)子节点
			sourceScreenID：动态数字(例如卡号)数据来源屏幕号；
			regexPattern：用来从数据来源屏幕号中提取出动态数字(例如卡号)字符串的正则表达式匹配模式串。

		4、DepositDetailTemplate(存款详细)子节点（作为模板声明使用）：
			sourceScreenID：存款金额数据来源屏幕号；
				Text(静态文本)子节点
					content：需要播放的静态文本内容；
				Denomination(面额)子节点
					（CNY|100:7;CNY|50:6; 中的50和100，会按照面额从小到大排序后的对应顺序输出）；
				Numbers(张数)子节点
					（CNY|100:7;CNY|50:6; 中的6和7，会按照面额从小到大排序后的对应顺序输出）；

		5、DepositTotalAmount(存款总金额)子节点
			sourceScreenID：存款金额数据来源屏幕号；
			（CNY|100:7;CNY|50:6; 中通过计算获得的1000： (100*7)+(50*6)=1000）。

	这里播放使用的是 Windows 系统自带的语音合成引擎。
-->

	<DynamicScreenTxt>
