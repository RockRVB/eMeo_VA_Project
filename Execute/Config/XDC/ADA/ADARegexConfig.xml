<!--
     这里设置动态金额语音播放需要的数目语音模板，最大支持11位数字（带两位小数点）：
	 NumbersAudio节点属性 
		- inputAmountPlayByWav：是否需要使用wav拼接播放的方式播放输入金额的语音；
			该属性语音文件查找路径如下：
				Resource\XDC\Voice\Common\000\，其中 000 为语言基数，若有多种语言，需要创建名字为对应的语言基数的文件夹，并保持文件夹内的数字语音文件名称相同，如 0 的语音就都需要为 0.wav
		- hStateInputNumberPlayOneByOneWithWav：是否需要启用“H状态输入数字逐个播放本地Wav数字音频”功能
			该属性语音文件查找路径如下：
				Resource\XDC\Voice\Common\000\，其中 000 为语言基数，若有多种语言，需要创建名字为对应的语言基数的文件夹，并保持文件夹内的数字语音文件名称相同，如 0 的语音就都需要为 0.wav
	 1、Item子节点
			name：（非必要情况下不要改动！！！）数目语音模板关键字，“百”使用“100”，“千”使用“1000”，以此类推；
			audioFileName：数目语音模板文件名，会根据语言基数到 Resource\XDC\Voice\Common\ 下不同的语言基数目录下面寻找，请保证每个语言基数目录下面对应数字的语音文件名均和下面设置的保持一致。
			
			注：如果不需要动态金额语音中出现 And，可以将下面 NumbersAudio 中 And 的 Item 配置行注释或删除即可。
-->
	<NumbersAudio inputAmountPlayByWav="0" hStateInputNumberPlayOneByOneWithWav="0">
		<Item name="0" audioFileName="0.wav"/>
		<Item name="1" audioFileName="1.wav"/>
		<Item name="2" audioFileName="2.wav"/>
		<Item name="3" audioFileName="3.wav"/>
		<Item name="4" audioFileName="4.wav"/>
		<Item name="5" audioFileName="5.wav"/>
		<Item name="6" audioFileName="6.wav"/>
		<Item name="7" audioFileName="7.wav"/>
		<Item name="8" audioFileName="8.wav"/>
		<Item name="9" audioFileName="9.wav"/>
		<Item name="10" audioFileName="10.wav"/>
		<Item name="11" audioFileName="11.wav"/>
		<Item name="12" audioFileName="12.wav"/>
		<Item name="13" audioFileName="13.wav"/>
		<Item name="14" audioFileName="14.wav"/>
		<Item name="15" audioFileName="15.wav"/>
		<Item name="16" audioFileName="16.wav"/>
		<Item name="17" audioFileName="17.wav"/>
		<Item name="18" audioFileName="18.wav"/>
		<Item name="19" audioFileName="19.wav"/>
