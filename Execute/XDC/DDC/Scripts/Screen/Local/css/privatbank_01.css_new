#F8_img{position:absolute;top:263px;left:310px;}
/* Text classes */
#withBg{background-image:url(../images/background_01.jpg);background-repeat:no-repeat;}
#welcomeText{position:absolute;top:30px;right:40px;text-align:center;font-family:Arial;font-weight:bold;font-size:22px;color:#ffffff;}
#screenNameText{position:absolute;top:140px;left:25px;text-align:center;width:750px;font-family:Arial;font-size:40px;color:#ffffff;}
#screenTopText{position:absolute;top:200px;left:25px;text-align:center;width:750px;font-family:Arial;font-size:27px;color:#ffffff;}
#screenBottomText{position:absolute;bottom:5px;left:25px;text-align:center;width:750px;font-family:Arial;font-size:18px;color:#ffffff;}
#timeText{position: absolute;top:60px;right:40px;text-align:center;font-family:Arial;font-weight:bold;font-size:22px;color:#ffffff;}
