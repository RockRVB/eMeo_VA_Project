.InputTable{position:absolute;background-image:url(../Images/controls/input_01.png);height:37px;width:184px;padding:10px;padding-bottom:0px;font-family:Arial;font-weight:bold;font-size:44px;text-align:center;color:#ffff00;}
/* Icons locations */
#F1_img{position:absolute;top:263px;right:310px;}
#F2_img{position:absolute;top:348px;right:310px;}
#F3_img{position:absolute;top:433px;right:310px;}
