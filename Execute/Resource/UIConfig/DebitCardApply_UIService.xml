  <Screen name="UI_CashInShowResultCard" uri="CreditCard\CountCashResult.html" cache="0">
    <Triggers>
      <EventTrigger condition="show">
        <PlaySound source="(Voice_CountingCashResult)"/>
      </EventTrigger>
      <PropertyTrigger target="F4" property="visible" value="0">
        <Setter target="prompt" property="visible" value="0"/>
        <Setter target="promptContinue" property="visible" value="0"/>
