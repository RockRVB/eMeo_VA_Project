  <Screen name="UI_InputPinCard" uri="CreditCard\SetPassword.html" cache="0">
    <Triggers>
      <EventTrigger condition="show">
        <Setter target="PromptIcon" property="visible" value="0"/>
      </EventTrigger>
      <EventTrigger condition="InputNewPinUnmatch">
        <Setter target="PromptIcon" property="visible" value="1"/>
        <Setter target="Prompt" property="content" value="(IDS_PasswordUnMatchTip)"/>
      </EventTrigger>
      <EventTrigger condition="LengthNotEnough">
        <Setter target="PromptIcon" property="visible" value="1"/>
        <Setter target="Prompt" property="content" value="(IDS_InputPinLengthNotEnough)"/>
      </EventTrigger>
    </Triggers>
  </Screen>
