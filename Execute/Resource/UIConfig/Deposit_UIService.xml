		<Triggers>
			<EventTrigger condition="show">
				<PlaySound source="(Voice_CountingButNoCash)"/>
			</EventTrigger>
			<EventTrigger condition="loadDenoFailure">
				<Setter target="divPrompt1" property="visible" value="0"/>
			</EventTrigger>
		</Triggers>
	</Screen>

