<?xml version="1.0" encoding="UTF-8"?>
<Screens>
	<!--操作进行中-->
	<Screen name="UI_OperatingNoCounter" uri="Foundation\OperatingNoCounter.html" cache="0">
		<Triggers>
			<EventTrigger condition="show">
				<PlaySound source="(Voice_TransactionIsBeing)"/>
			</EventTrigger>
		</Triggers>
	</Screen>
	<Screen name="UI_CashInStart" uri="Foundation\OperatingNoCounter.html" cache="0">
		<Triggers>
			<EventTrigger condition="show">
				<PlaySound source="(Voice_TransactionIsBeing)"/>
			</EventTrigger>
		</Triggers>
	</Screen>
