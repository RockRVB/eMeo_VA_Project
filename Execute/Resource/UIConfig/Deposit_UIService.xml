	<Screen name="UI_CancelWaitForNoteTaken" uri="Deposit\WaitCustomerToTakeCashForCancel.html" cache="0">
		<Triggers>
			<EventTrigger condition="show">
				<PlaySound source="(Voice_CancelDepositPleaseTakeCash)"/>
			</EventTrigger>
		</Triggers>  
	</Screen>

